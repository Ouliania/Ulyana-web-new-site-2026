---
import { Image } from 'astro:assets';
import logo from '../assets/logo.png';

const pathname = Astro.url.pathname;
const isHome = pathname === '/' || pathname === '';
---
<header class="main-header">
  <div class="container header-container">
    <a href="/" class="logo-wrapper" aria-label="Ulyana Kirpichnikova" style="display:flex;align-items:center;text-decoration:none;">
      <Image src={logo} alt="Ulyana Kirpichnikova" style="height:36px;width:auto;display:block;" format="webp" />
    </a>

    {/* Mobile menu toggle using pure CSS state checker for robustness */}
    <input type="checkbox" id="menu-toggle" class="menu-toggle-checkbox" aria-label="Открыть меню" />
    <label for="menu-toggle" class="menu-toggle-label">
      <span></span>
      <span></span>
      <span></span>
    </label>

    <nav class="nav-menu">
      <div class="nav-links-wrapper">
        <a href={isHome ? "#cases" : "/#cases"} class="nav-link">Кейсы</a>
        <a href={isHome ? "#reviews" : "/#reviews"} class="nav-link">Отзывы</a>
        <a href="/code" class="nav-link">Сайт на коде</a>
        <a href="/audit" class="nav-link">Аудиты</a>
        <a href="/ai-visibility-audit" class="nav-link">ИИ-видимость</a>
        <a href="/blog" class="nav-link">Блог</a>
        <a href="/contacts" class="nav-link">Контакты</a>
      </div>
      
      <div class="nav-ctas">
        <a href="https://t.me/UlyanaKir" target="_blank" rel="noopener noreferrer" class="btn btn-primary btn-sm-mobile">
          Написать в tg
        </a>
      </div>
    </nav>
  </div>
</header>

<style>
  .main-header {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 100;
    background: var(--color-bg);
    height: 80px;
    display: flex;
    align-items: center;
  }

  .header-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
  }

  /* Logo */
  .logo-wrapper {
    display: flex;
    align-items: center;
    text-decoration: none;
    flex-shrink: 0;
    z-index: 10;
  }

  /* Navigation */
  .nav-menu {
    display: flex;
    align-items: center;
    flex: 1;
    gap: 2rem;
    justify-content: flex-end;
    min-width: 0;
  }

  .nav-links-wrapper {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex: 1;
    justify-content: center;
  }

  .nav-link {
    font-size: 0.9rem;
    font-weight: normal;
    color: var(--color-text-secondary);
    transition: color 0.15s ease;
  }

  .nav-link:hover {
    color: var(--color-text-primary);
  }

  .nav-ctas {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    z-index: 10;
  }

  .btn-sm-mobile {
    padding: 0.4rem 1rem;
    font-size: 0.95rem;
    font-weight: normal;
  }

  /* Hamburger Checklist toggle */
  .menu-toggle-checkbox {
    display: none;
  }

  .menu-toggle-label {
    display: none;
    flex-direction: column;
    gap: 5px;
    cursor: pointer;
    z-index: 102;
  }

  .menu-toggle-label span {
    display: block;
    width: 22px;
    height: 2px;
    background-color: var(--color-text-primary);
    transition: transform 0.25s ease, opacity 0.25s ease;
  }

  @media (max-width: 991px) {
    .menu-toggle-label {
      display: flex;
    }

    .nav-menu {
      position: fixed;
      top: 0;
      right: -100%;
      width: 75vw;
      max-width: 320px;
      height: 100vh;
      background: var(--color-bg);
      border-left: 1px solid var(--color-border);
      flex-direction: column;
      justify-content: center;
      gap: 2.5rem;
      padding: 3rem;
      transition: right 0.35s cubic-bezier(0.25, 1, 0.5, 1);
      z-index: 101;
      flex-grow: 0;
      align-items: center;
    }

    .nav-links-wrapper {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 2.5rem;
      position: static;
      transform: none;
      width: 100%;
    }

    .nav-ctas {
      flex-direction: column;
      width: 100%;
      gap: 1rem;
    }

    .nav-ctas a {
      width: 100%;
    }

    /* CSS states via checked status */
    body:has(.menu-toggle-checkbox:checked) .nav-menu {
      right: 0;
    }

    body:has(.menu-toggle-checkbox:checked) .menu-toggle-label span:nth-child(1) {
      transform: translateY(7px) rotate(45deg);
    }

    body:has(.menu-toggle-checkbox:checked) .menu-toggle-label span:nth-child(2) {
      opacity: 0;
    }

    body:has(.menu-toggle-checkbox:checked) .menu-toggle-label span:nth-child(3) {
      transform: translateY(-7px) rotate(-45deg);
    }
  }
</style>
