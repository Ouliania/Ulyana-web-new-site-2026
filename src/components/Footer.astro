---
import { Image } from 'astro:assets';
import logo from '../assets/logo.png';

const pathname = Astro.url.pathname;
const isHome = pathname === '/' || pathname === '';
const currentYear = new Date().getFullYear();
---

<footer class="main-footer">
  <div class="container footer-grid">
    <div class="footer-brand">
      <a href="/" class="logo-wrapper">
        <Image src={logo} alt="Ульяна Кирпичникова" class="logo-img" format="webp" />
      </a>
      <p class="brand-tagline">
        Делаю сайты для бизнеса как инструмент продаж. Смысловая структура, дизайн, верстка и запуск под ключ.
      </p>
    </div>

    <div class="footer-nav-group">
      <h4 class="footer-title">Разделы</h4>
      <nav class="footer-nav" aria-label="Служебное меню">
        <a href={isHome ? "#hero" : "/#hero"}>Главная</a>
        <a href={isHome ? "#cases" : "/#cases"}>Кейсы</a>
        <a href={isHome ? "#reviews" : "/#reviews"}>Отзывы</a>
        <a href="/audit">Аудит конверсии</a>
        <a href="/ai-visibility-audit">Видимость AI</a>
        <a href="/blog">Блог</a>
        <a href="/contacts">Контакты</a>
      </nav>
    </div>

    <div class="footer-nav-group">
      <h4 class="footer-title">Контакты и Соцсети</h4>
      <nav class="footer-nav" aria-label="Контакты">
        <a href="https://t.me/UlyanaKir" target="_blank" rel="noopener noreferrer">Telegram: @UlyanaKir</a>
        <a href="mailto:hello@ulyanaweb.ru">hello@ulyanaweb.ru</a>
        <a href="https://github.com/ulyanaweb" target="_blank" rel="noopener noreferrer">GitHub</a>
      </nav>
    </div>
  </div>

  <div class="container footer-bottom">
    <p>&copy; {currentYear} Ульяна Кирпичникова. Все права защищены.</p>
    <p class="legal-links">
      <a href="/privacy-policy" class="legal-link">Политика конфиденциальности</a>
      <span class="tech-stack-info">Сайт собран на Astro + CSS (100/100 Core Web Vitals)</span>
    </p>
  </div>
</footer>

<style>
  .main-footer {
    background: var(--color-bg-subtle);
    border-top: 1px solid var(--color-border);
    padding-block-start: 5rem;
    padding-block-end: 2rem;
    font-size: 0.95rem;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    margin-block-end: 4rem;

    @media (min-width: 768px) {
      grid-template-columns: 2fr 1fr 1fr;
    }
  }

  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  /* Logo styling matching the screenshot */
  .logo-wrapper {
    display: inline-flex;
    align-items: center;
    text-decoration: none;
  }

  .logo-img {
    height: 32px;
    width: auto;
    display: block;
    object-fit: contain;
  }

  .brand-tagline {
    max-inline-size: 380px;
    line-height: 1.6;
    color: var(--color-text-secondary);
  }

  .footer-title {
    font-family: var(--font-heading);
    font-size: 1.05rem;
    font-weight: normal;
    margin-block-end: 1.5rem;
    color: var(--color-text-primary);
  }

  .footer-nav {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .footer-nav a {
    color: var(--color-text-secondary);
    transition: color 0.15s ease;
  }

  .footer-nav a:hover {
    color: var(--color-text-primary);
  }

  .footer-bottom {
    border-top: 1px solid var(--color-border);
    padding-block-start: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    justify-content: space-between;
    align-items: center;
    color: var(--color-text-muted);
    font-size: 0.85rem;

    @media (min-width: 768px) {
      flex-direction: row;
    }
  }

  .legal-links {
    display: flex;
    gap: 1.5rem;
    align-items: center;
  }

  .legal-link {
    color: var(--color-text-secondary);
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: color 0.15s ease;
  }

  .legal-link:hover {
    color: var(--color-text-primary);
  }

  .tech-stack-info {
    color: var(--color-text-secondary);
    font-weight: 600;
  }
</style>
