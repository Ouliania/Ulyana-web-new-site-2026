<script>
  const initServicesScroll = () => {
    const triggerElements = document.querySelectorAll('.scroll-trigger-v2');
    const detailCards = document.querySelectorAll('.content-card');
    const titleItems = document.querySelectorAll('.title-item');
    
    if (triggerElements.length === 0) return; // Prevent errors on pages without this component

    // Desktop sticky scroll observer
    const desktopOptions = {
      root: null,
      rootMargin: '-30% 0px -40% 0px',
      threshold: 0
    };

    const desktopObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const index = parseInt(entry.target.getAttribute('data-index') || '0', 10);
          activateCard(index);
        }
      });
    }, desktopOptions);

    // Mobile viewport scroll reveal observer
    const mobileOptions = {
      root: null,
      rootMargin: '0px 0px -12% 0px',
      threshold: 0.1
    };

    const mobileObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
        }
      });
    }, mobileOptions);

    const activateCard = (activeIndex: number) => {
      // 1. Update active states for cards
      detailCards.forEach((card, idx) => {
        if (idx === activeIndex) {
          card.classList.add('active');
        } else {
          card.classList.remove('active');
        }
      });

      // 2. Update active states for titles
      titleItems.forEach((item, idx) => {
        if (idx === activeIndex) {
          item.classList.add('active');
        } else {
          item.classList.remove('active');
        }
      });
    };

    // Click navigation for desktop titles
    const titleButtons = document.querySelectorAll('.title-button');
    titleButtons.forEach(btn => {
      btn.addEventListener('click', () => {
        const idx = parseInt(btn.getAttribute('data-index') || '0', 10);
        const triggers = document.querySelectorAll('.scroll-trigger-v2');
        const targetTrigger = triggers[idx];
        if (targetTrigger) {
          const rect = targetTrigger.getBoundingClientRect();
          const absoluteTop = rect.top + window.scrollY;
          window.scrollTo({
            top: absoluteTop - 12 * (window.innerHeight / 100) + 1, // Subtract 12vh to align perfectly with scroll-margin-top
            behavior: 'smooth'
          });
          // Instantly activate card for immediate visual feedback
          activateCard(idx);
        }
      });
    });

    const handleResize = () => {
      if (window.innerWidth >= 992) {
        // Desktop: observe scroll-triggers and manage sticky crossfades
        mobileObserver.disconnect();
        triggerElements.forEach(trigger => desktopObserver.observe(trigger));
        
        // Remove visible class used in mobile stack to prevent conflicts
        detailCards.forEach(card => card.classList.remove('visible'));
        
        // Ensure at least the first card is active initially
        const activeCard = document.querySelector('.content-card.active');
        if (!activeCard) {
          activateCard(0);
        }
      } else {
        // Mobile: observe cards directly for simple scroll fade-in
        desktopObserver.disconnect();
        detailCards.forEach(card => {
          card.classList.remove('active');
          mobileObserver.observe(card);
        });
        titleItems.forEach(item => item.classList.remove('active'));
      }
    };

    handleResize();
    window.addEventListener('resize', handleResize);
  };

  // Run on load and after Astro page transitions if any
  document.addEventListener('DOMContentLoaded', initServicesScroll);
  document.addEventListener('astro:after-swap', initServicesScroll);
</script>
