---
interface TabItem {
  id: string;
  title: string;
  fullDesc: string;
}

const tabs: TabItem[] = [
  {
    id: "leads",
    title: "Увеличить заявки с сайта",
    fullDesc: "Нахожу где и почему вы теряете клиентов и исправляю это. Через Аналитику, понимание целевой аудитории и психологию принятия решений"
  },
  {
    id: "ads",
    title: "Подготовить сайт к рекламе",
    fullDesc: "Подготовлю сайт или страницу сайта, чтобы она была готова принимать и прогревать холодный трафик, ведя клиента к покупке"
  },
  {
    id: "hypothesis",
    title: "Быстро проверить гипотезу",
    fullDesc: "Анализирую целевую аудиторию и продукт и запускаю от 1 до 3 вариантов лендингов для бытсрого теста гипотез. От старта до запуска 3-х дней"
  },
  {
    id: "new-product",
    title: "Нужен новый сайт или продукт",
    fullDesc: "Вы выходите на рынок с новым направлением, запускаете продукт или вам нужно заново, понятно, солидно и авторитетно рассказать о компании, отсекая конкурентов с первого взгляда."
  },
  {
    id: "brand",
    title: "Сайт как имиджевая страница",
    fullDesc: "Ваши клиенты — крупный B2B-бизнес, продажи идут через холодные контакты, конференции или тендеры. Нужен сайт, который подтвердит вашу репутацию, покажет системный подход и выступит финальной точкой доверия."
  },
  {
    id: "segment",
    title: "Сфокусировать на прибыльном сегменте",
    fullDesc: "Хотите перепозиционировать бизнес и сделать сайт более эффективным под более платеспособную аудиторию, сфокусироваться на высокомаржинальном сегменте, поднять чеки и качество входящих заявок."
  }
];
---

<div class="services-scroll-container">
  {/* Scroll Triggers for Desktop IntersectionObserver */}
  <div class="scroll-triggers-v2">
    {tabs.map((tab, index) => (
      <div class="scroll-trigger-v2" data-index={index}></div>
    ))}
  </div>

  <div class="sticky-wrapper-v2">
    <div class="container">
      
      {/* Title above the content */}
      <div class="services-header-v2">
        <h2 class="section-title">С какими задачами я работаю</h2>
      </div>

      {/* Unified Dashboard Box with Solid Borders */}
      <div class="services-dashboard-box">
        
        {/* Right Column: Titles List & Accordions */}
        <div class="scroll-titles-column">
          <ul class="titles-list">
            {tabs.map((tab, index) => (
              <li 
                class="title-item" 
                data-index={index}
              >
                <button class="title-button" data-index={index} aria-label={`Показать ${tab.title}`}>
                  <span class="item-text">{tab.title}</span>
                </button>
                <div class="item-accordion-content">
                  <div class="accordion-inner">
                    <p class="accordion-body-text">{tab.fullDesc}</p>
                  </div>
                </div>
              </li>
            ))}
          </ul>
        </div>
        
        {/* Left Column: Content Cards (Graphics) */}
        <div class="scroll-content-column">
          <div class="content-cards-wrapper">
            {tabs.map((tab, index) => (
              <article 
                class="content-card" 
                id={`scroll-card-${index}`}
                data-index={index}
              >
                <div class="content-card-inner">
                  
                  {/* Mobile-only header and text */}
                  <div class="mobile-card-header">
                    <h3 class="mobile-card-title">{tab.title}</h3>
                  </div>
                  
                  <div class="content-card-text">
                    <p class="card-body-text">{tab.fullDesc}</p>
                  </div>
                  
                  {/* Right part of active card: Graphic Widget */}
                  <div class="graphic-wrapper">
                    <div class="graphic-widget-box">
                      
                      {/* Common Background Radar and Jade Glass Orb */}
                      <div class="radar-background">
                        <div class="ripple-ring ring-1"></div>
                        <div class="ripple-ring ring-2"></div>
                        <div class="ripple-ring ring-3"></div>
                      </div>
                      
                      {/* leads Infographic */}
                      {tab.id === 'leads' && (
                        <div class="info-leads-bold">
                          <div class="leads-floating-container">
                            <div class="glass-widget-card leads-card-before">
                              <div class="card-header-row">
                                <span class="card-icon-wrapper red-icon">
                                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M23 18l-9-9-5 5-8-8"/>
                                    <path d="M17 18h6v-6"/>
                                  </svg>
                                </span>
                                <span class="card-badge badge-warning">Аналитика</span>
                              </div>
                              <div class="card-value-display">
                                <span class="card-val-label">Отказы в корзине</span>
                                <span class="card-val-main font-heading">-64%</span>
                              </div>
                              <div class="card-metadata-list">
                                <div class="meta-row">
                                  <span class="meta-label">Причина:</span>
                                  <span class="meta-value">Перегруз формы</span>
                                </div>
                                <div class="meta-row">
                                  <span class="meta-label">Аудит:</span>
                                  <span class="meta-value val-alert">Критично</span>
                                </div>
                              </div>
                            </div>

                            <div class="glass-widget-card leads-card-after">
                              <div class="card-header-row">
                                <span class="card-icon-wrapper green-icon">
                                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M23 6l-9 9-5-5-8 8"/>
                                    <path d="M17 6h6v6"/>
                                  </svg>
                                </span>
                                <span class="card-badge badge-success">Результат</span>
                              </div>
                              <div class="card-value-display">
                                <span class="card-val-label">Конверсия в лид</span>
                                <span class="card-val-main font-heading">16.4%</span>
                              </div>
                              <div class="card-metadata-list">
                                <div class="meta-row">
                                  <span class="meta-label">Рост:</span>
                                  <span class="meta-value font-semibold">х4.2 раза</span>
                                </div>
                                <div class="meta-row">
                                  <span class="meta-label">Статус:</span>
                                  <span class="meta-value val-success">Исправлено</span>
                                </div>
                              </div>
                            </div>
                          </div>
                        </div>
                      )}

                      {/* ads Infographic */}
                      {tab.id === 'ads' && (
                        <div class="info-ads-bold">
                          <div class="ads-floating-container">
                            <div class="glass-widget-card ads-card ads-card-1">
                              <div class="card-header-row">
                                <span class="card-badge badge-dark">Подготовка</span>
                              </div>
                              <div class="card-value-display">
                                <span class="card-val-label">Ценностный оффер</span>
                                <span class="card-val-main-small">Смысл сайта</span>
                              </div>
                              <div class="card-metadata-list">
                                <div class="meta-row">
                                  <span class="meta-label">Релевантность:</span>
                                  <span class="meta-value val-success">100%</span>
                                </div>
                              </div>
                            </div>

                            <div class="ads-flow-line line-1"></div>

                            <div class="glass-widget-card ads-card ads-card-2">
                              <div class="card-header-row">
                                <span class="card-badge badge-neutral">Трафик</span>
                              </div>
                              <div class="card-value-display">
                                <span class="card-val-label">Рекламные каналы</span>
                                <span class="card-val-main-small">Яндекс / Google</span>
                              </div>
                              <div class="card-metadata-list">
                                <div class="meta-row">
                                  <span class="meta-label">Аудитория:</span>
                                  <span class="meta-value">Горячая</span>
                                </div>
                              </div>
                            </div>

                            <div class="ads-flow-line line-2"></div>

                            <div class="glass-widget-card ads-card ads-card-3">
                              <div class="card-header-row">
                                <span class="card-badge badge-success">Заявка</span>
                              </div>
                              <div class="card-value-display">
                                <span class="card-val-label">Конверсия трафика</span>
                                <span class="card-val-main-small">Лид получен!</span>
                              </div>
                              <div class="card-metadata-list">
                                <div class="meta-row">
                                  <span class="meta-label">Стоимость CPL:</span>
                                  <span class="meta-value val-success">-42%</span>
                                </div>
                              </div>
                            </div>
                          </div>
                        </div>
                      )}

                      {/* hypothesis Infographic */}
                      {tab.id === 'hypothesis' && (
                        <div class="info-hypothesis-bold">
                          <div class="hypothesis-floating-container">
                            <div class="glass-widget-card sprint-card sprint-card-done sprint-card-1">
                              <div class="sprint-day">День 1</div>
                              <div class="sprint-status-row">
                                <span class="sprint-badge status-done">Done</span>
                              </div>
                              <div class="sprint-body-text">Анализ аудитории и скелет лендинга</div>
                            </div>

                            <div class="glass-widget-card sprint-card sprint-card-done sprint-card-2">
                              <div class="sprint-day">День 2</div>
                              <div class="sprint-status-row">
                                <span class="sprint-badge status-done">Done</span>
                              </div>
                              <div class="sprint-body-text">Дизайн интерфейса и упаковка смыслов</div>
                            </div>

                            <div class="glass-widget-card sprint-card sprint-card-active sprint-card-3">
                              <div class="sprint-day">День 3</div>
                              <div class="sprint-status-row">
                                <span class="sprint-badge status-active">Active</span>
                              </div>
                              <div class="sprint-body-text">Интеграция и запуск теста</div>
                              <div class="sprint-glow-pulse"></div>
                            </div>
                          </div>
                        </div>
                      )}

                      {/* new-product Infographic */}
                      {tab.id === 'new-product' && (
                        <div class="info-product-bold">
                          <div class="product-floating-container">
                            <div class="glass-widget-card mockup-browser-card">
                              <div class="browser-header-mock">
                                <div class="browser-dots-mock">
                                  <span class="b-dot"></span>
                                  <span class="b-dot"></span>
                                  <span class="b-dot"></span>
                                </div>
                                <div class="browser-address-mock">new-site.ru</div>
                              </div>
                              <div class="browser-viewport-mock">
                                
                                {/* Mock Navigation Menu Bar */}
                                <div class="mock-navbar">
                                  <div class="mock-logo">
                                    <span class="logo-dot"></span>
                                    <span class="logo-text">BRAND</span>
                                  </div>
                                  <div class="mock-nav-links">
                                    <span class="nav-link-pill"></span>
                                    <span class="nav-link-pill"></span>
                                    <span class="nav-link-pill"></span>
                                  </div>
                                  <div class="mock-nav-cta"></div>
                                </div>

                                {/* Mock Hero Section */}
                                <div class="mockup-hero-glass">
                                  <div class="hero-left">
                                    <div class="hero-tag-mock"></div>
                                    <div class="hero-title-mock"></div>
                                    <div class="hero-subtitle-mock"></div>
                                    <div class="hero-btn-row">
                                      <div class="hero-button-mock primary-btn"></div>
                                      <div class="hero-button-mock secondary-btn"></div>
                                    </div>
                                  </div>
                                  <div class="hero-right">
                                    <div class="hero-card-mock">
                                      <div class="hero-card-chart">
                                        <div class="chart-bar bar-a"></div>
                                        <div class="chart-bar bar-b"></div>
                                        <div class="chart-bar bar-c"></div>
                                      </div>
                                    </div>
                                  </div>
                                </div>

                                {/* Mock Features Row */}
                                <div class="mockup-features-row">
                                  <div class="feat-box-mock">
                                    <div class="feat-icon-mock icon-green"></div>
                                    <div class="feat-text-1"></div>
                                    <div class="feat-text-2"></div>
                                  </div>
                                  <div class="feat-box-mock">
                                    <div class="feat-icon-mock icon-black"></div>
                                    <div class="feat-text-1"></div>
                                    <div class="feat-text-2"></div>
                                  </div>
                                  <div class="feat-box-mock">
                                    <div class="feat-icon-mock icon-accent"></div>
                                    <div class="feat-text-1"></div>
                                    <div class="feat-text-2"></div>
                                  </div>
                                </div>

                              </div>
                            </div>
                          </div>
                        </div>
                      )}

                      {/* brand Infographic */}
                      {tab.id === 'brand' && (
                        <div class="info-brand-bold">
                          <div class="brand-floating-container">
                            <div class="glass-widget-card brand-trust-card">
                              <div class="card-header-row">
                                <span class="card-badge badge-success">B2B Имидж</span>
                                <span class="trust-status-indicator">Online</span>
                              </div>
                              
                              <div class="trust-items-stack">
                                <div class="trust-item-row">
                                  <span class="trust-dot-bullet green-bullet"></span>
                                  <div class="trust-item-details">
                                    <span class="trust-title-lbl">Позиционирование репутации</span>
                                    <span class="trust-value-lbl">Экспертность & Лидерство</span>
                                  </div>
                                </div>
                                <div class="trust-divider-line"></div>
                                <div class="trust-item-row">
                                  <span class="trust-dot-bullet green-bullet"></span>
                                  <div class="trust-item-details">
                                    <span class="trust-title-lbl">Финальная точка доверия</span>
                                    <span class="trust-value-lbl">Сделка без возражений</span>
                                  </div>
                                </div>
                                <div class="trust-divider-line"></div>
                                <div class="trust-item-row">
                                  <span class="trust-dot-bullet green-bullet"></span>
                                  <div class="trust-item-details">
                                    <span class="trust-title-lbl">Фильтр конкурентов</span>
                                    <span class="trust-value-lbl">Авторитет с первого взгляда</span>
                                  </div>
                                </div>
                              </div>
                            </div>
                          </div>
                        </div>
                      )}

                      {/* segment Infographic */}
                       {tab.id === 'segment' && (
                        <div class="info-segment-bold">
                          <div class="segment-floating-container">
                            
                            {/* Card 1: Mass Market (Low Margin) */}
                            <div class="glass-widget-card segment-card-mass">
                              <div class="card-header-row">
                                <span class="card-badge badge-dark">Масс-маркет</span>
                              </div>
                              <div class="card-value-display">
                                <span class="card-val-label">Заявки без фильтра</span>
                                <span class="card-val-main-small">Низкий чек</span>
                              </div>
                              <div class="card-metadata-list">
                                <div class="meta-row">
                                  <span class="meta-label">Маржа:</span>
                                  <span class="meta-value val-alert">Минимальная</span>
                                </div>
                                <div class="meta-row">
                                  <span class="meta-label">Суета:</span>
                                  <span class="meta-value">100%</span>
                                </div>
                              </div>
                            </div>

                            {/* Card 2: Focus Segment (Premium B2B) */}
                            <div class="glass-widget-card segment-card-premium">
                              <div class="card-header-row">
                                <span class="card-badge badge-success">Фокус B2B</span>
                              </div>
                              <div class="card-value-display">
                                <span class="card-val-label">Целевой сегмент</span>
                                <span class="card-val-main-small val-green">Высокий чек</span>
                              </div>
                              <div class="card-metadata-list">
                                <div class="meta-row">
                                  <span class="meta-label">Прибыль:</span>
                                  <span class="meta-value val-success">+320%</span>
                                </div>
                                <div class="meta-row">
                                  <span class="meta-label">Фокус:</span>
                                  <span class="meta-value font-semibold">20% клиентов</span>
                                </div>
                              </div>
                            </div>

                          </div>
                        </div>
                      )}
                      


                    </div>
                  </div>
                  
                </div>
              </article>
            ))}
          </div>
        </div>

      </div>
    </div>
  </div>
</div>

<style>
  .services-scroll-container {
    position: relative;
    width: 100%;
    height: auto;
  }

  @media (min-width: 992px) {
    .services-scroll-container {
      height: calc(6 * 95vh); /* Tall container for scroll pinning */
    }
  }

  .scroll-triggers-v2 {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    display: none;
  }

  @media (min-width: 992px) {
    .scroll-triggers-v2 {
      display: flex;
      flex-direction: column;
      height: 100%;
    }
  }

  .scroll-trigger-v2 {
    flex: 1;
  }

  .sticky-wrapper-v2 {
    position: relative;
    width: 100%;
    height: auto;
    z-index: 1;
  }

  @media (min-width: 992px) {
    .sticky-wrapper-v2 {
      position: sticky;
      top: 12vh;
      height: 76vh;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
    }
  }

  .services-header-v2 {
    width: 100%;
    margin-bottom: 2.5rem;
    text-align: left;
  }

  .services-header-v2 .section-title {
    font-family: var(--font-heading);
    font-size: var(--fs-h2);
    font-weight: normal;
    color: var(--color-text-primary);
    margin: 0;
  }

  @media (min-width: 992px) {
    .services-dashboard-box {
      display: grid;
      grid-template-columns: 50% 50%;
      gap: 3.5rem;
      min-height: 480px;
      height: auto;
      align-items: center;
    }
  }

  /* Right Column Styles (now the Accordion menu) */
  .scroll-titles-column {
    display: flex;
    flex-direction: column;
    width: 100%;
  }

  @media (max-width: 991px) {
    .scroll-titles-column {
      display: none;
    }
  }

  @media (min-width: 992px) {
    .scroll-titles-column {
      grid-column: 2;
      grid-row: 1;
      width: 100%;
      height: 100%;
      display: flex;
      flex-direction: column;
      justify-content: center;
      box-sizing: border-box;
      padding-left: 0.5rem;
    }
  }

  .titles-list {
    display: flex;
    flex-direction: column;
    padding: 0;
    margin: 0;
    width: 100%;
  }

  .title-item {
    position: relative;
    width: 100%;
  }

  .title-button {
    display: flex;
    align-items: center;
    text-align: left;
    width: 100%;
    cursor: pointer;
    background: transparent;
    border: none;
    padding: 1.25rem 1.5rem;
    transition: background-color 0.25s ease;
    box-sizing: border-box;
  }

  @media (min-width: 992px) {
    .title-button {
      padding: 0.6rem 1.0rem;
    }
  }

  .item-text {
    font-family: var(--font-heading);
    font-size: 1.35rem;
    color: var(--color-text-primary);
    opacity: 0.35;
    line-height: 1.3;
    transition: opacity 0.25s, color 0.25s, font-weight 0.25s;
  }

  .title-item.active {
    background-color: transparent;
  }

  .title-item.active .item-text {
    opacity: 1;
    font-weight: 600 !important;
  }

  /* Accordion Layout */
  .item-accordion-content {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.35s cubic-bezier(0.25, 1, 0.5, 1);
    overflow: hidden;
  }

  .title-item.active .item-accordion-content {
    grid-template-rows: 1fr;
  }

  .accordion-inner {
    min-height: 0;
    opacity: 0;
    transform: translateY(-8px);
    transition: opacity 0.35s ease, transform 0.35s cubic-bezier(0.25, 1, 0.5, 1);
  }

  .title-item.active .accordion-inner {
    opacity: 1;
    transform: translateY(0);
  }

  .accordion-body-text {
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--color-text-secondary);
    line-height: 1.65;
    margin: 0;
    max-width: 31.25rem; /* 500px in rem */
    padding: 0.5rem 1rem 1.25rem 1rem;
    text-align: left;
  }

  /* Left Column Styles (now the Graphic column) */
  .scroll-content-column {
    position: relative;
    width: 100%;
  }

  @media (min-width: 992px) {
    .scroll-content-column {
      grid-column: 1;
      grid-row: 1;
      width: 100%;
      height: 100%;
    }
  }

  .content-cards-wrapper {
    position: relative;
    width: 100%;
    display: flex;
    flex-direction: column;
    height: auto;
  }

  @media (min-width: 992px) {
    .content-cards-wrapper {
      display: block;
      height: 100%;
    }
  }

  .content-card {
    background: transparent;
    box-sizing: border-box;
    width: 100%;
    padding: 2rem;
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }

  .content-card.visible {
    opacity: 1;
    transform: translateY(0);
  }

  @media (min-width: 992px) {
    .content-card {
      position: absolute;
      inset: 0;
      opacity: 0;
      visibility: hidden;
      transform: translateY(10px);
      transition: opacity 0.4s cubic-bezier(0.25, 1, 0.5, 1), 
                  transform 0.4s cubic-bezier(0.25, 1, 0.5, 1), 
                  visibility 0.4s;
      padding: 0;
      border-bottom: none;
    }

    .content-card.active {
      opacity: 1;
      visibility: visible;
      transform: translateY(0);
      z-index: 2;
    }
  }

  /* Mobile layout headers and content cards text */
  .mobile-card-header {
    margin-bottom: 0.75rem;
  }

  .mobile-card-title {
    font-family: var(--font-heading);
    font-size: 1.4rem;
    font-weight: 600;
    color: var(--color-text-primary);
    margin: 0;
  }

  .content-card-text {
    width: 100%;
    margin-bottom: 1.5rem;
  }

  .card-body-text {
    font-size: 1rem;
