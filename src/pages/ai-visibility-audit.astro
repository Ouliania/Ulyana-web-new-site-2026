---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const aiAuditSchema = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "Аудит видимости сайта в ИИ-поисковиках (AI Search / GEO Audit)",
  "image": "https://ulyanaweb.ru/og-image.png",
  "description": "Профессиональный технический и смысловой аудит готовности вашего сайта к рекомендациям в системах ИИ (ChatGPT, Gemini, Perplexity).",
  "offers": {
    "@type": "Offer",
    "price": "30000",
    "priceCurrency": "RUB",
    "valueAddedTaxIncluded": "true",
    "priceValidUntil": "2026-12-31"
  }
};
---

<Layout 
  title="Аудит видимости сайта в ИИ-поисковиках (AI Search Audit) — UlyanaWeb"
  description="Проверьте, готов ли ваш сайт к рекомендациям в ChatGPT, Gemini и Perplexity. Найдем технические и смысловые ошибки, мешающие ИИ считывать ваш бизнес. Стоимость: 30 000 руб."
  schema={aiAuditSchema}
>
  <Header />

  <main class="ai-audit-page">
    {/* Section 1: Hero */}
    <section class="hero-section section-padding">
      <div class="container hero-container">
        <div class="hero-badge">
          <span>✦ AI Visibility Audit · GEO Audit · UlyanaWeb</span>
        </div>
        
        <h1 class="hero-title text-center">
          Проверьте, готов ли ваш сайт<br />
          к поиску с помощью ИИ.
        </h1>
        
        <p class="hero-subtitle text-center">
          Поисковые ИИ-системы и современные генеративные алгоритмы требуют структурированную, надежную и авторитетную информацию. Мы проведем аудит вашего сайта и покажем, что мешает ему быть понятным и рекомендованным.
        </p>

        <div class="hero-actions">
          <a href="#pricing" class="btn btn-primary">Получить AI-аудит — 30 000 ₽</a>
          <a href="/audit" class="btn btn-secondary">Аудит конверсии лендинга</a>
        </div>
        
        <p class="hero-footnote text-center">
          Практичный технический и смысловой аудит сайта. Без пустых обещаний.
        </p>

        {/* Section 1b: Browser Mockup of the Report */}
        <div class="hero-dashboard-mockup">
          <div class="dashboard-header-bar">
            <div class="dashboard-dots">
              <span class="dot-red"></span>
              <span class="dot-yellow"></span>
              <span class="dot-green"></span>
            </div>
            <span class="dashboard-title">launchaudit.net/ai-visibility-report.pdf</span>
          </div>
          
          <div class="dashboard-grid">
            {/* Left Column (1/3 width) */}
            <div class="dashboard-col col-left">
              <div class="dashboard-card-inner">
                <span class="card-label-mini">AI-Readiness Score</span>
                <div class="score-display">
                  <span class="score-number-big">54</span>
                  <span class="score-total">/100</span>
                </div>
                <div class="score-progress-bar">
                  <div class="score-progress-fill" style="width: 54%;"></div>
                </div>
                <span class="score-status-label">Needs improvement</span>
              </div>

              <div class="dashboard-card-inner">
                <span class="card-label-mini">Quick summary</span>
                <ul class="summary-list-items">
                  <li>
                    <span class="list-key">Structured data</span>
                    <span class="list-value val-bad">✗ Missing</span>
                  </li>
                  <li>
                    <span class="list-key">Business clarity</span>
                    <span class="list-value val-warn">⚠ Partial</span>
                  </li>
                  <li>
                    <span class="list-key">Trust signals</span>
                    <span class="list-value val-warn">⚠ Partial</span>
                  </li>
                  <li>
                    <span class="list-key">FAQ content</span>
                    <span class="list-value val-bad">✗ Missing</span>
                  </li>
                  <li>
                    <span class="list-key">Crawlability</span>
                    <span class="list-value val-good">✓ Good</span>
                  </li>
                </ul>
              </div>
            </div>

            {/* Right Column (2/3 width) */}
            <div class="dashboard-col col-right">
              <div class="dashboard-card-inner">
                <span class="card-label-mini">Top Priority Fix #1</span>
                <p class="priority-fix-text">
                  <strong>Добавьте блоки вопросов и ответов (FAQ) на страницы услуг.</strong> Поисковые ИИ-системы чаще всего ссылаются на те ресурсы, которые дают прямой ответ на конкретные пользовательские запросы. На вашем текущем сайте контент в формате «вопрос-ответ» полностью отсутствует.
                </p>
              </div>

              <div class="dashboard-card-inner">
                <span class="card-label-mini">Areas reviewed</span>
                <div class="reviewed-tags-wrapper">
                  <span class="reviewed-tag">✓ Business clarity</span>
                  <span class="reviewed-tag">✓ Schema opportunities</span>
                  <span class="reviewed-tag">✓ Trust signal review</span>
                  <span class="reviewed-tag">✓ FAQ gap review</span>
                  <span class="reviewed-tag">✓ Technical SEO basics</span>
                  <span class="reviewed-tag">✓ Action plan</span>
                  <span class="reviewed-tag">✓ Crawlability</span>
                  <span class="reviewed-tag">✓ Internal linking</span>
                </div>
              </div>

              <div class="dashboard-card-inner deliverable-summary-card">
                <span class="card-label-mini label-accent">Deliverable</span>
                <p>Полный отчет в формате PDF с оценкой готовности к ИИ, списком приоритетных задач, анализом Schema.org и контентных пробелов.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    {/* Section 2: Why this matters (How search bots index information) */}
    <section class="why-matters-section section-padding">
      <div class="container text-center">
        <span class="section-badge-blue">Why this matters</span>
        <h2 class="section-title">Как поисковые роботы индексируют информацию</h2>
        <p class="section-subtitle-centered">
          Поисковые агенты используют большие языковые модели для анализа вашего сайта. Если они не находят четких структурированных данных — они просто исключают вас из выдачи.
        </p>

        <div class="discovery-workflow-container">
          <h4 class="workflow-title">Схема взаимодействия ИИ-поиска</h4>
          <div class="workflow-grid-box">
            <div class="workflow-step">
              <div class="step-card">
                <h5>Ваш сайт</h5>
                <p>Ясность · Структура · Доверие</p>
              </div>
            </div>
            <div class="workflow-arrow">➔</div>
            <div class="workflow-step">
              <div class="step-card active-card">
                <h5>ИИ-поисковики</h5>
                <div class="step-tags">
                  <span>ChatGPT</span>
                  <span>Perplexity</span>
                  <span>Gemini</span>
                  <span>Google AI</span>
                </div>
              </div>
            </div>
            <div class="workflow-arrow">➔</div>
            <div class="workflow-step">
              <div class="step-card">
                <h5>Клиенты</h5>
                <p>Поиск · Доверие · Рекомендация</p>
              </div>
            </div>
          </div>
          <p class="workflow-footnote">
            Если сайт не структурирован для ботов — эти системы не смогут порекомендовать вас в результатах выдачи.
          </p>
        </div>
      </div>
    </section>

    {/* Section 3: Who it's for */}
    <section class="audience-section section-padding">
      <div class="container text-center">
        <span class="section-badge-blue">Who it's for</span>
        <h2 class="section-title">Для кого этот аудит</h2>
        <p class="section-subtitle-centered">
          Любому бизнесу, который хочет быть понятым ИИ-ассистентами и поисковыми роботами.
        </p>
        
        <div class="audience-tags-grid">
          <span>Местные услуги</span>
          <span>SaaS платформы</span>
          <span>Консультанты</span>
          <span>Медицинские клиники</span>
          <span>Недвижимость</span>
          <span>Интернет-магазины</span>
          <span>Агентства</span>
          <span>Профессиональные услуги</span>
        </div>
        
        <p class="audience-footer-text">
          Если у вашего бизнеса есть сайт и вы хотите, чтобы ИИ-ассистенты и поисковые системы рекомендовали вас пользователям — этот аудит для вас.
        </p>
      </div>
    </section>

    {/* Section 4: Before vs After */}
    <section class="before-after-section section-padding">
      <div class="container">
        <div class="section-header text-center">
          <span class="section-badge-blue">What changes</span>
          <h2 class="section-title">От хаоса к структуре и авторитету</h2>
        </div>

        <div class="before-after-grid">
          {/* Before Column */}
          <div class="comp-column before-col">
            <h4>До аудита</h4>
            <ul class="comp-list">
              <li><span>—</span> Запутанный сайт — сложный для понимания людьми и ИИ</li>
              <li><span>—</span> Тонкое описание услуг без понятной структуры</li>
              <li><span>—</span> Отсутствие FAQ-блоков и структурированных ответов</li>
              <li><span>—</span> Слабые или незаметные сигналы авторитета бизнеса</li>
              <li><span>—</span> Отсутствие микроразметки Schema.org</li>
            </ul>
          </div>

          {/* After Column */}
          <div class="comp-column after-col">
            <h4>После аудита</h4>
            <ul class="comp-list">
              <li><span class="check-blue">✓</span> Четкое позиционирование и логичная структура</li>
              <li><span class="check-blue">✓</span> Структурированные блоки, легко считываемые ИИ-ботами</li>
              <li><span class="check-blue">✓</span> FAQ-разделы, отвечающие на реальные поисковые вопросы</li>
              <li><span class="check-blue">✓</span> Сильные сигналы доверия в правильных местах сайта</li>
              <li><span class="check-blue">✓</span> Пошаговый план по внедрению Schema.org разметки</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    {/* Section 5: What you receive */}
    <section class="deliverables-section section-padding">
      <div class="container">
        <div class="section-header text-center">
          <span class="section-badge-blue">Deliverables</span>
          <h2 class="section-title">Что вы получаете на руки</h2>
        </div>

        <div class="grid-2 deliverables-grid">
          <div class="glass-card deliverable-item-card">
            <h3>Отчет AI Visibility PDF</h3>
            <p>Полный письменный отчет по всем проверенным параметрам готовности сайта.</p>
          </div>
          
          <div class="glass-card deliverable-item-card">
            <h3>Оценка ясности позиционирования</h3>
            <p>Разбор понятности вашего предложения для нейросетевых моделей.</p>
          </div>

          <div class="glass-card deliverable-item-card">
            <h3>Чек-лист готовности к ИИ</h3>
            <p>Сводная таблица показателей технического и контентного состояния сайта.</p>
          </div>

          <div class="glass-card deliverable-item-card">
            <h3>Анализ пробелов FAQ-контента</h3>
            <p>Список вопросов клиентов, на которые у вас на сайте пока нет ответов.</p>
          </div>

          <div class="glass-card deliverable-item-card">
            <h3>Анализ базового технического SEO</h3>
            <p>Детальный чек метатегов, структуры заголовков H-тегов и доступов ботов.</p>
          </div>

          <div class="glass-card deliverable-item-card">
            <h3>Карта Schema.org</h3>
            <p>Готовые шаблоны и рекомендации по внедрению микроразметки для страниц услуг.</p>
          </div>

          <div class="glass-card deliverable-item-card">
            <h3>Анализ сигналов доверия</h3>
            <p>Список правок для улучшения параметров авторитетности бизнеса (E-E-A-T).</p>
          </div>

          <div class="glass-card deliverable-item-card">
            <h3>Приоритетный план действий</h3>
            <p>Пошаговый список изменений с расставленными приоритетами (High / Medium).</p>
          </div>
        </div>

        {/* Small report preview mockup inside deliverables section */}
        <div class="deliverable-report-preview-mockup">
          <div class="dashboard-header-bar">
            <span class="dashboard-title">Sample Report Preview</span>
            <span class="badge-mini-pdf">PDF</span>
          </div>
          <div class="preview-mockup-body">
            <div class="preview-row">
              <span class="preview-label">AI-Readiness Score</span>
              <div class="preview-score-stat">
                <strong>54</strong><span>/100</span>
              </div>
            </div>
            <div class="preview-bar-bg"><div class="preview-bar-fill" style="width: 54%;"></div></div>
            
            <div class="preview-fix-block">
              <h6>Top Priority Fix #1</h6>
              <p>Добавьте блоки вопросов и ответов (FAQ) на страницы услуг. Поисковые ИИ-системы чаще всего ссылаются на те ресурсы, которые дают прямой ответ на конкретные пользовательские запросы.</p>
            </div>
            
            <div class="preview-tags-row">
              <span>✓ Clarity review</span>
              <span>✓ Schema opportunities</span>
              <span>✓ Trust signal review</span>
              <span>✓ FAQ gap review</span>
              <span>✓ Technical SEO basics</span>
              <span>✓ Action plan</span>
            </div>
          </div>
        </div>
        <p class="deliverable-footnote text-center">
          Внедрение правок и верстка ТЗ в стоимость аудита не входят и могут быть рассчитаны отдельно.
        </p>
      </div>
    </section>

    {/* Section 6: Scope (Explore what the search bots indicator understood - Tabbed Widget) */}
    <section class="scope-section section-padding">
      <div class="container">
        <div class="section-header text-center">
          <span class="section-badge-blue">Audit scope</span>
          <h2 class="section-title">Проверьте, что видит и понимает индикатор ИИ</h2>
        </div>

        <div class="tabs-widget-container">
          <div class="tabs-buttons-row">
            <button class="tab-btn active" data-tab="ai-score" role="tab" aria-selected="true">ИИ-оценка (AI Score)</button>
            <button class="tab-btn" data-tab="technical" role="tab" aria-selected="false">Техническая готовность</button>
            <button class="tab-btn" data-tab="content" role="tab" aria-selected="false">Контент-структура</button>
            <button class="tab-btn" data-tab="trust" role="tab" aria-selected="false">Факторы доверия (Trust)</button>
          </div>
          
          <div class="glass-card tab-content-card">
            {/* Tab 1: AI Score */}
            <div class="tab-content active" id="tab-ai-score" role="tabpanel">
              <div class="tab-content-grid">
                <div class="tab-content-text">
                  <h3>Ясность позиционирования и ИИ-читаемость</h3>
                  <p>Мы оцениваем общую читаемость вашего контента для LLM моделей. Проверяем, насколько легко ИИ вычленяет суть предложений, нет ли смысловой перегруженности, и насколько четко выделено уникальное торговое предложение (УТП) вашего бизнеса.</p>
                  <ul class="tab-content-list">
                    <li><span>✓</span> <strong>Ясность позиционирования:</strong> Анализируем, насколько понятно нейросетевым моделям, чем именно занимается ваш бизнес, для кого предназначен продукт и чем вы отличаетесь от конкурентов.</li>
                    <li><span>✓</span> <strong>Поиск смысловых барьеров:</strong> Выявляем абстрактные фразы и "воду", которые мешают ИИ правильно обобщить суть вашей страницы.</li>
                  </ul>
                </div>
                <div class="tab-content-visual">
                  <div class="visual-score-card">
                    <span class="visual-label">AI Clarity Indicator</span>
                    <div class="visual-score-number">94<span class="total">/100</span></div>
                    <div class="visual-score-progress"><div class="fill" style="width: 94%"></div></div>
                    <span class="visual-status-label status-good">Отличная читаемость</span>
                  </div>
                </div>
              </div>
            </div>

            {/* Tab 2: Technical */}
            <div class="tab-content" id="tab-technical" role="tabpanel">
              <div class="tab-content-grid">
                <div class="tab-content-text">
                  <h3>robots.txt, Schema.org и HTML-структура</h3>
                  <p>Проверка доступов для ИИ-краулеров в robots.txt (разрешение для GPTBot, PerplexityBot, ClaudeBot). Составление семантической карты Schema.org разметки (Organization, WebSite, Service, FAQPage, Article), чтобы роботы читали данные в структурированном виде.</p>
                  <ul class="tab-content-list">
                    <li><span>✓</span> <strong>Доступность для краулеров:</strong> Проверка настроек файлов robots.txt и заголовков на предмет отсутствия блокировок для ботов ИИ.</li>
                    <li><span>✓</span> <strong>Возможности разметки Schema:</strong> Анализ точек внедрения микроразметки, помогающей связать элементы сайта в понятную роботам семантику.</li>
                    <li><span>✓</span> <strong>Базовое техническое SEO:</strong> Корректность заполнения тегов Title, Meta Description и структуры заголовков H-тегов.</li>
                  </ul>
                </div>
                <div class="tab-content-visual">
                  <div class="visual-code-card">
                    <div class="code-header"><span>JSON-LD Schema</span><span class="status-badge">Valid</span></div>
                    <pre class="code-preview"><code is:raw>{
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Аудит видимости сайта в ИИ",
  "provider": {
    "@type": "LocalBusiness",
    "name": "UlyanaWeb"
  }
}</code></pre>
                  </div>
                </div>
              </div>
            </div>

            {/* Tab 3: Content */}
            <div class="tab-content" id="tab-content" role="tabpanel">
              <div class="tab-content-grid">
                <div class="tab-content-text">
                  <h3>FAQ-блоки и Q&A Архитектура</h3>
                  <p>Анализ текстовых блоков на наличие ответов на реальные вопросы пользователей (FAQ). Создание разделов с прямыми ответами повышает вероятность цитирования вашего сайта в ИИ-выдачах (GEO/Generative Engine Optimization).</p>
                  <ul class="tab-content-list">
                    <li><span>✓</span> <strong>Пробелы FAQ-контента:</strong> Поиск упущенных вопросов, которые клиенты задают нейросетям о ваших услугах. Составим список тем для создания Q&A блоков.</li>
                    <li><span>✓</span> <strong>Структура страниц услуг:</strong> Проверка иерархии заголовков и смысловых тегов, позволяющих ИИ-ботам легко парсить страницу и вычленять основные тезисы.</li>
                    <li><span>✓</span> <strong>Внутренняя перелинковка:</strong> Анализ связей между страницами, помогающих роботам выстраивать правильный тематический граф вашего ресурса.</li>
                  </ul>
                </div>
                <div class="tab-content-visual">
                  <div class="visual-faq-card">
                    <span class="visual-label">FAQ Chunk Detection</span>
                    <div class="faq-item">
                      <div class="faq-q">Как ИИ считывает ваш сайт?</div>
                      <div class="faq-a">Через парсинг HTML-кода, метаданные, семантические связи и структурированные FAQ-блоки, которые дают прямые и четкие ответы.</div>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            {/* Tab 4: Trust */}
            <div class="tab-content" id="tab-trust" role="tabpanel">
              <div class="tab-content-grid">
                <div class="tab-content-text">
                  <h3>Сигналы авторитета E-E-A-T</h3>
                  <p>Оценка сигналов авторитетности и экспертности бизнеса для ИИ. Проверка наличия отзывов, кейсов с конкретными цифрами, страниц об авторах/экспертах, юридической информации и ссылок на внешние упоминания, подтверждающие репутацию компании.</p>
                  <ul class="tab-content-list">
                    <li><span>✓</span> <strong>Сигналы авторитета E-E-A-T:</strong> Проверка индикаторов экспертности: наличие страниц авторов, ссылок на профили, дипломов, сертификатов и юр. реквизитов.</li>
                    <li><span>✓</span> <strong>Факты и кейсы:</strong> Поиск на страницах конкретных кейсов и измеримых результатов, которые ИИ-системы считывают как сигналы высокой авторитетности.</li>
                  </ul>
                </div>
                <div class="tab-content-visual">
                  <div class="visual-trust-card">
                    <div class="trust-metric">
                      <span class="metric-title">E-E-A-T Signal Strength</span>
                      <div class="metric-value">Высокий</div>
                    </div>
                    <div class="trust-signals-list">
                      <span>✓ Профиль автора подтвержден</span>
