<script>
  // Simple Requests Form handler
  const initRequestForm = () => {
    const finalForm = document.getElementById('finalRequestForm') as HTMLFormElement;
    const finalStatus = document.getElementById('finalStatusMsg');

    if (finalForm && finalStatus) {
      finalForm.addEventListener('submit', (e) => {
        e.preventDefault();
        finalStatus.textContent = "Отправка...";
        finalStatus.className = "form-status";
        
        setTimeout(() => {
          finalStatus.textContent = "Спасибо! Заявка принята. Я свяжусь с вами в ближайшее время.";
          finalStatus.className = "form-status success";
          finalForm.reset();
        }, 1200);
      });
    }
  };

  // Interactive Tabs Widget handler
  const initTabs = () => {
    const tabsContainer = document.querySelector('.tabs-widget-container');
    if (!tabsContainer) return;
    
    const buttons = tabsContainer.querySelectorAll('.tab-btn');
    const contents = tabsContainer.querySelectorAll('.tab-content');
    
    buttons.forEach(btn => {
      btn.addEventListener('click', () => {
        const tabId = btn.getAttribute('data-tab');
        
        // Update active class on buttons
        buttons.forEach(b => {
          b.classList.remove('active');
          b.setAttribute('aria-selected', 'false');
        });
        btn.classList.add('active');
        btn.setAttribute('aria-selected', 'true');
        
        // Update active class on contents
        contents.forEach(c => {
          c.classList.remove('active');
          if (c.id === `tab-${tabId}`) {
            c.classList.add('active');
          }
        });
      });
    });
  };

  document.addEventListener('DOMContentLoaded', () => {
    initRequestForm();
    initTabs();
  });
</script>
