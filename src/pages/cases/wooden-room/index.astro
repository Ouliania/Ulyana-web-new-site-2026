          footerDesc: "We are committed to setting up distinctive themes, to bring the most wonderful stories filled with authentic Sri Lankan experiences to life.",
          privacy: "Privacy Policy",
          terms: "Terms & Conditions",
          sitemap: "Sitemap",
          gdpr: "GDPR Compliance"
        }
      };

      let currentLang = 'Eng';

      /* --- INITIALIZE TRANSLATION FUNCTION --- */
      function applyTranslations(lang) {
        currentLang = lang;
        document.getElementById('active-lang').textContent = lang;
        
        // Translate elements with data-t
        document.querySelectorAll('[data-t]').forEach(el => {
          const key = el.getAttribute('data-t');
          if (translations[lang] && translations[lang][key]) {
            el.innerHTML = translations[lang][key];
          }
        });
        
        // Translate placeholders
        document.querySelectorAll('[data-t-placeholder]').forEach(el => {
          const key = el.getAttribute('data-t-placeholder');
          if (translations[lang] && translations[lang][key]) {
            el.setAttribute('placeholder', translations[lang][key]);
          }
        });

        // Recalculate and update calculated summaries in the correct language
        updateCalculator();
      }

      /* --- NAVBAR LANGUAGE DROPDOWN --- */
      const langBtn = document.getElementById('lang-toggle-btn');
      const langDropdown = document.getElementById('lang-dropdown-menu');

      langBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        langDropdown.classList.toggle('active');
      });

      document.querySelectorAll('.lang-option').forEach(opt => {
        opt.addEventListener('click', () => {
          const selected = opt.getAttribute('data-lang');
          applyTranslations(selected);
          langDropdown.classList.remove('active');
        });
      });

      document.addEventListener('click', () => {
        langDropdown.classList.remove('active');
      });

      /* --- HOTEL SELECTOR DROPDOWN --- */
      const hotelSelector = document.getElementById('hotel-selector');
      const hotelDropdown = document.getElementById('hotel-dropdown');
      const selectedHotelName = document.getElementById('selected-hotel-name');

      hotelSelector.addEventListener('click', (e) => {
        e.stopPropagation();
        hotelDropdown.classList.toggle('active');
      });

      document.querySelectorAll('.hotel-option').forEach(opt => {
        opt.addEventListener('click', () => {
          selectedHotelName.textContent = opt.textContent;
          hotelDropdown.classList.remove('active');
        });
      });

      document.addEventListener('click', () => {
        hotelDropdown.classList.remove('active');
      });

      /* --- SLIDER LOGIC --- */
      const sliderDataEl = document.getElementById('slider-data-container');
      const sliderImages = JSON.parse(sliderDataEl.getAttribute('data-images'));
      
      let activeIndex = 0;
      const mainImg = document.getElementById('slider-main-img');
      const thumbs = document.querySelectorAll('.slider-thumb');
      
      function updateSlider(index) {
        activeIndex = index;
        mainImg.src = sliderImages[index];
        thumbs.forEach(t => t.classList.remove('active'));
        thumbs[index].classList.add('active');
      }

      document.getElementById('slider-prev-btn').addEventListener('click', () => {
        let newIndex = activeIndex === 0 ? sliderImages.length - 1 : activeIndex - 1;
        updateSlider(newIndex);
      });

      document.getElementById('slider-next-btn').addEventListener('click', () => {
        let newIndex = activeIndex === sliderImages.length - 1 ? 0 : activeIndex + 1;
        updateSlider(newIndex);
      });

      thumbs.forEach((thumb, idx) => {
        thumb.addEventListener('click', () => {
          updateSlider(idx);
        });
      });

      /* --- GALLERY ACCORDION LOGIC --- */
      const slides = document.querySelectorAll('.gallery-slide');
      slides.forEach(slide => {
        slide.addEventListener('mouseenter', () => {
          slides.forEach(s => s.classList.remove('expanded'));
          slide.classList.add('expanded');
        });
      });

      /* --- CALCULATOR INTERACTIVE LOGIC --- */
      // State
      let adults = 2;
      let kids = 1;
      let checkInDate = "2025-06-05";
      let checkOutDate = "2025-06-12";
      
      // Selectors
      const checkInWidget = document.getElementById('check-in-widget');
      const checkOutWidget = document.getElementById('check-out-widget');
      const checkInCalc = document.getElementById('check-in-calc');
      const checkOutCalc = document.getElementById('check-out-calc');
      
      const adultCountEl = document.getElementById('adult-count');
      const kidsCountEl = document.getElementById('kids-count');
      
      const extraBreakfast = document.getElementById('extra-breakfast');
      const extraHb = document.getElementById('extra-hb');
      const extraAirport = document.getElementById('extra-airport');
      const extraLateCheckout = document.getElementById('extra-late-checkout');
      const extraCrib = document.getElementById('extra-crib');
      
      // Event Sync
      function syncDates(type, val) {
        if (type === 'checkin') {
          checkInDate = val;
          checkInWidget.value = val;
          checkInCalc.value = val;
        } else {
          checkOutDate = val;
          checkOutWidget.value = val;
          checkOutCalc.value = val;
        }
        updateCalculator();
      }

      checkInWidget.addEventListener('change', (e) => syncDates('checkin', e.target.value));
      checkInCalc.addEventListener('change', (e) => syncDates('checkin', e.target.value));
      checkOutWidget.addEventListener('change', (e) => syncDates('checkout', e.target.value));
      checkOutCalc.addEventListener('change', (e) => syncDates('checkout', e.target.value));

      // Mutual exclusive meals
      extraBreakfast.addEventListener('change', () => {
        if (extraBreakfast.checked) extraHb.checked = false;
        updateCalculator();
      });
      extraHb.addEventListener('change', () => {
        if (extraHb.checked) extraBreakfast.checked = false;
        updateCalculator();
      });
      
      extraAirport.addEventListener('change', updateCalculator);
      extraLateCheckout.addEventListener('change', updateCalculator);
      extraCrib.addEventListener('change', updateCalculator);

      // Counters
      document.getElementById('btn-adults-plus').addEventListener('click', () => {
        adults++;
        adultCountEl.textContent = adults;
        updateCalculator();
      });
      document.getElementById('btn-adults-minus').addEventListener('click', () => {
        if (adults > 1) {
          adults--;
          adultCountEl.textContent = adults;
          updateCalculator();
        }
      });
      document.getElementById('btn-kids-plus').addEventListener('click', () => {
        kids++;
        kidsCountEl.textContent = kids;
        updateCalculator();
      });
      document.getElementById('btn-kids-minus').addEventListener('click', () => {
        if (kids > 0) {
          kids--;
          kidsCountEl.textContent = kids;
          updateCalculator();
        }
      });

      // Format Date in local language
      function formatDateLocal(dateStr, lang) {
        const d = new Date(dateStr);
        if (isNaN(d.getTime())) return dateStr;
        
        const monthsRu = ["января", "февраля", "марта", "апреля", "мая", "июня", "июля", "августа", "сентября", "октября", "ноября", "декабря"];
        const monthsEn = ["January", "February", "March", "April", "May", "June", "July", "August", "September", "October", "November", "December"];
        
        if (lang === 'Rus') {
          return `${d.getDate()} ${monthsRu[d.getMonth()]} ${d.getFullYear()}`;
        }
        return `${d.getFullYear()} ${monthsEn[d.getMonth()]} ${String(d.getDate()).padStart(2, '0')}`;
      }

      function formatDateShort(dateStr, lang) {
        const d = new Date(dateStr);
        if (isNaN(d.getTime())) return dateStr;
        
        const options = lang === 'Rus' 
          ? { day: 'numeric', month: 'short' } 
          : { month: 'short', day: 'numeric' };
          
        return d.toLocaleDateString(lang === 'Rus' ? 'ru-RU' : 'en-US', options);
      }

      // Calculation Core
      function updateCalculator() {
        // Calculate Nights
        const d1 = new Date(checkInDate);
        const d2 = new Date(checkOutDate);
        let nights = 7;
        if (!isNaN(d1.getTime()) && !isNaN(d2.getTime())) {
          const diff = d2.getTime() - d1.getTime();
          nights = Math.max(1, Math.ceil(diff / (1000 * 60 * 60 * 24)));
        }

        // Nightly rate base
        let baseRate = 150;
        // Extra guests
        if (adults > 2) baseRate += (adults - 2) * 40;
        if (kids > 0) baseRate += kids * 20;

        const totalGuests = adults + kids;
        
        // Meal plans
        let mealRate = 0;
        let mealLabel = currentLang === 'Rus' ? "Без питания" : "No meals";
        if (extraBreakfast.checked) {
          mealRate = totalGuests * 15;
          mealLabel = currentLang === 'Rus' ? "Завтрак" : "Breakfast";
        } else if (extraHb.checked) {
          mealRate = totalGuests * 35;
          mealLabel = currentLang === 'Rus' ? "Завтрак и ужин" : "Half board";
        }
        
        // Room Cost for nights
        const roomNightsCost = (baseRate + mealRate) * nights;

        // Flat fee extras
        let flatExtras = 0;
        if (extraAirport.checked) flatExtras += 50;
        if (extraLateCheckout.checked) flatExtras += 40;
        if (extraCrib.checked) flatExtras += 15;

        // Totals
        const subtotal = roomNightsCost + flatExtras;
        const discount = subtotal * 0.1;
        const grandTotal = subtotal - discount;

        // Update Right panel displays
        document.getElementById('summary-check-in').innerHTML = `${formatDateLocal(checkInDate, currentLang)} <span style="font-size:12px;color:var(--color-gray-text);">${currentLang === 'Rus' ? "после 14:00" : "after 2:00 PM"}</span>`;
        document.getElementById('summary-check-out').innerHTML = `${formatDateLocal(checkOutDate, currentLang)} <span style="font-size:12px;color:var(--color-gray-text);">${currentLang === 'Rus' ? "до 12:00" : "before 12:00 PM"}</span>`;
        
        document.getElementById('summary-kids').textContent = kids;
        document.getElementById('summary-adults').textContent = adults;
        
        // Meals and Transfer
        document.getElementById('summary-meals-label').textContent = mealLabel;
        const mealsIncl = document.getElementById('summary-meals-included');
        if (extraBreakfast.checked || extraHb.checked) {
          mealsIncl.textContent = translations[currentLang].included;
          mealsIncl.style.color = "var(--color-black)";
        } else {
          mealsIncl.textContent = currentLang === 'Rus' ? "не включено" : "not included";
          mealsIncl.style.color = "var(--color-gray-text)";
        }

        const transIncl = document.getElementById('summary-transfer-included');
        if (extraAirport.checked) {
          transIncl.textContent = translations[currentLang].included;
          transIncl.style.color = "var(--color-black)";
        } else {
          transIncl.textContent = currentLang === 'Rus' ? "не включено" : "not included";
          transIncl.style.color = "var(--color-gray-text)";
        }

        // Nights calculation row
        const nightsLabel = currentLang === 'Rus' ? `За ${nights} ночей` : `Per ${nights} nights`;
        document.getElementById('summary-nights-label').textContent = nightsLabel;
        document.getElementById('summary-nights-calc').textContent = `$${(baseRate + mealRate)} x ${nights} = $${roomNightsCost}`;

        // Discount
        document.getElementById('summary-discount').textContent = `10% (-$${discount.toFixed(0)})`;

        // Total
        document.getElementById('calc-total-val').textContent = `$ ${grandTotal.toFixed(0)}`;

        // Dates Bottom info
        document.getElementById('summary-arrival-date-bottom').textContent = formatDateLocal(checkInDate, currentLang);
        document.getElementById('summary-departure-date-bottom').textContent = formatDateLocal(checkOutDate, currentLang);
      }

      // Initial Call
      updateCalculator();
    </script>
  </body>
</html>
