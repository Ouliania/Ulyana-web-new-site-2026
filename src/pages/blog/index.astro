---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

// Fetch and sort blog posts
const posts = (await getCollection('blog'))
  .filter(post => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const title = "Блог Ульяны Кирпичниковой | Мысли о сайтах, конверсиях и дизайне";
const description = "Личный блог про веб-разработку, копирайтинг, конверсии сайтов, оптимизацию и продвижение в поисковых и ИИ-системах.";
---

<Layout title={title} description={description} isBlog={true}>
  <Header />

  <main class="blog-main section-padding">
    <div class="container">
      <div class="blog-header">
        <h1 class="blog-title">Блог.</h1>
        <p class="blog-subtitle">Мысли, инсайты и разборы о создании сайтов, которые приносят прибыль.</p>
      </div>

      {posts.length === 0 ? (
        <div class="glass-card text-center" style="padding: 4rem;">
          <p>В блоге пока нет опубликованных статей. Загляните позже!</p>
        </div>
      ) : (
        <div class="grid-2 blog-grid">
          {posts.map(post => (
            <article class="glass-card blog-card">
              <div class="blog-card-meta">
                <time datetime={post.data.pubDate.toISOString()}>
                  {post.data.pubDate.toLocaleDateString('ru-RU', {
                    year: 'numeric',
                    month: 'long',
                    day: 'numeric'
                  })}
                </time>
                <div class="blog-card-tags">
                  {post.data.tags.map(tag => (
                    <span class="blog-tag">{tag}</span>
                  ))}
                </div>
              </div>
              
              <h2 class="blog-card-title">
                <a href={`/blog/${post.id}/`}>{post.data.title}</a>
              </h2>
              
              <p class="blog-card-desc">{post.data.description}</p>
              
              <a href={`/blog/${post.id}/`} class="read-more-link">
                Читать статью ➔
              </a>
            </article>
          ))}
        </div>
      )}
    </div>
  </main>

  <Footer />
</Layout>

<style>
  .blog-main {
    padding-block-start: 120px;
    min-block-size: 80vh;
  }

  .blog-header {
    max-inline-size: 600px;
    margin-block-end: 4rem;
  }

  .blog-title {
    font-size: var(--fs-h1);
    margin-block-end: 1rem;
    color: var(--color-text-primary);
  }

  .blog-subtitle {
    font-size: 1.2rem;
    line-height: 1.6;
    color: var(--color-text-secondary);
  }

  .blog-grid {
    gap: 2.5rem;
  }

  .blog-card {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    height: 100%;
    justify-content: space-between;
  }

  .blog-card-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  .blog-card-tags {
    display: flex;
    gap: 0.5rem;
  }

  .blog-tag {
    background: var(--color-bg-subtle);
    border: 1px solid var(--color-border);
    color: var(--color-text-secondary);
    padding: 0.2rem 0.5rem;
    border-radius: var(--radius-default);
    font-size: 0.75rem;
    font-weight: 600;
  }

  .blog-card-title {
    font-size: var(--fs-h3);
    line-height: 1.3;
    color: var(--color-text-primary);
    transition: color 0.15s ease;
  }

  .blog-card-title a:hover {
    color: var(--color-accent-text);
  }

  .blog-card-desc {
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--color-text-secondary);
    flex-grow: 1;
  }

  .read-more-link {
    font-family: var(--font-heading);
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-text-primary);
    align-self: flex-start;
    transition: color 0.15s ease, transform 0.15s;
  }

  .read-more-link:hover {
    color: var(--color-accent-text);
    transform: translateX(4px);
  }
</style>
