                />
              </div>
              <button type="submit" class="btn btn-primary" style="width: 100%;">
                Обсудить сайт на коде
              </button>
              <div id="formStatusMsg" class="form-status" aria-live="polite"></div>
            </form>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

