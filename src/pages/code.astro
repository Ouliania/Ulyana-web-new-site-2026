<script>
  import { GOOGLE_SCRIPT_URL } from '../config';

  // Dynamic Benchmark script logic
  const initBenchmark = () => {
    const startBtn = document.getElementById('start-benchmark');
    if (!startBtn) return;

    // elements
    const astroBar = document.getElementById('astro-bar');
    const astroScore = document.getElementById('astro-score');
    const astroSize = document.getElementById('astro-size');
    const astroTime = document.getElementById('astro-time');

    const builderBar = document.getElementById('builder-bar');
    const builderScore = document.getElementById('builder-score');
    const builderSize = document.getElementById('builder-size');
    const builderTime = document.getElementById('builder-time');

    let isRunning = false;

    startBtn.addEventListener('click', () => {
      if (isRunning) return;
      isRunning = true;
      startBtn.textContent = 'Тестирование...';
      startBtn.setAttribute('disabled', 'true');

      // Reset
      if (astroBar && builderBar && astroScore && builderScore && astroSize && builderSize && astroTime && builderTime) {
        astroBar.style.width = '0%';
        builderBar.style.width = '0%';
        astroScore.textContent = '0 / 100';
        builderScore.textContent = '0 / 100';
        astroSize.textContent = '0 KB';
        builderSize.textContent = '0.0 MB';
        astroTime.textContent = '0.0s';
        builderTime.textContent = '0.0s';

        // Animate Astro (fast, green, high performance)
        let astroVal = 0;
        const astroInterval = setInterval(() => {
          astroVal += 2;
          if (astroVal >= 100) {
            astroVal = 100;
            clearInterval(astroInterval);
          }
          astroBar.style.width = `${astroVal}%`;
          astroScore.textContent = `${astroVal} / 100`;
          
          if (astroVal >= 90) {
            astroBar.style.backgroundColor = '#22c55e'; // Green
            astroScore.style.color = '#2b7a0b';
          } else {
            astroBar.style.backgroundColor = 'var(--color-text-primary)';
          }

          // Sizes and loading time updates
          astroSize.textContent = `${Math.round(astroVal * 0.45)} KB`;
          astroTime.textContent = `${(astroVal * 0.002).toFixed(2)}s`;
        }, 15);

        // Animate Builder (slower, red/yellow, low performance)
        let builderVal = 0;
        const builderInterval = setInterval(() => {
          builderVal += 1;
          if (builderVal >= 42) {
            builderVal = 42;
            clearInterval(builderInterval);
            isRunning = false;
            startBtn.textContent = 'Запустить тест заново';
            startBtn.removeAttribute('disabled');
          }
          builderBar.style.width = `${builderVal}%`;
          builderScore.textContent = `${builderVal} / 100`;

          if (builderVal < 50) {
            builderBar.style.backgroundColor = '#f85149'; // Red
            builderScore.style.color = '#f85149';
          } else {
            builderBar.style.backgroundColor = '#d29922'; // Yellow
            builderScore.style.color = '#d29922';
          }

          builderSize.textContent = `${(builderVal * 0.08).toFixed(1)} MB`;
          builderTime.textContent = `${(builderVal * 0.08).toFixed(1)}s`;
        }, 30);
      }
    });
  };

  // Form submit handler
  const initForm = () => {
    const form = document.getElementById('codeOrderForm') as HTMLFormElement;
    const statusMsg = document.getElementById('formStatusMsg');

    if (form && statusMsg) {
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        statusMsg.textContent = 'Отправка...';
        statusMsg.className = 'form-status';
        statusMsg.style.color = 'var(--color-text-primary)';

        if (!GOOGLE_SCRIPT_URL) {
          // Имитация отправки при пустом URL
          setTimeout(() => {
            statusMsg.textContent = 'Спасибо! Ваша заявка принята (Имитация). Настройте GOOGLE_SCRIPT_URL в src/config.ts.';
            statusMsg.className = 'form-status success';
            statusMsg.style.color = '#2b7a0b';
            form.reset();
          }, 1200);
          return;
        }

        try {
          const params = new URLSearchParams();
          const formData = new FormData(form);
          for (const [key, value] of formData.entries()) {
            params.append(key, value);
          }
          params.append('source', 'Заказ сайта (Сайт на коде)');

          await fetch(GOOGLE_SCRIPT_URL, {
            method: 'POST',
            mode: 'no-cors',
            headers: {
              'Content-Type': 'application/x-www-form-urlencoded'
            },
            body: params.toString()
          });

          statusMsg.textContent = 'Спасибо! Ваша заявка принята. Я свяжусь с вами в Telegram/WhatsApp в ближайшее время.';
          statusMsg.className = 'form-status success';
          statusMsg.style.color = '#2b7a0b';
          form.reset();
        } catch (err) {
          console.error(err);
          statusMsg.textContent = 'Ошибка отправки. Пожалуйста, напишите мне напрямую в Telegram.';
          statusMsg.className = 'form-status error';
          statusMsg.style.color = '#f85149';
        }
      });
    }
  };

  // Interactive Code Tabs handler
  const initCodeTabs = () => {
    const tabs = document.querySelectorAll('.code-tab');
    const contents = document.querySelectorAll('.code-file-content');

    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        const file = tab.getAttribute('data-file');
        
        // Deactivate all
        tabs.forEach(t => t.classList.remove('active'));
        contents.forEach(c => c.classList.remove('active'));

        // Activate selected
        tab.classList.add('active');
        const targetContent = document.getElementById(`file-${file}`);
        if (targetContent) targetContent.classList.add('active');
      });
    });
  };

  document.addEventListener('DOMContentLoaded', () => {
    initBenchmark();
    initForm();
    initCodeTabs();
  });
</script>
