---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import ServicesScroll from '../components/ServicesScroll.astro';
import Footer from '../components/Footer.astro';

// Cases data structure matching Block 3
const cases = [
  {
    title: "B2B сайт для производителя промышленного оборудования",
    niche: "Промышленное производство и инжиниринг",
    task: "Отсечь нецелевые запросы со средним чеком до 500 000 ₽ и увеличить поток заявок на крупные проекты от 3 000 000 ₽.",
    whatSawAndDid: "Предыдущий сайт рассказывал про винты и гайки, привлекая мелких покупателей, которые тратили время менеджеров. Мы полностью пересобрали логику: выдвинули на первый план инженерную экспертизу компании, показали системный процесс проектирования, добавили блок о надежности и внедрили опросник-фильтр на входе.",
    result: "Количество нецелевых звонков снизилось на 70%, при этом поток квалифицированных заявок на индивидуальное проектирование вырос на 35%. Менеджеры сфокусировались на крупных клиентах."
  },
  {
    title: "Лендинг для B2B SaaS-платформы автоматизации складов",
    niche: "IT и облачные сервисы для бизнеса",
    task: "Подготовить посадочную страницу к запуску контекстной рекламы в Яндекс Директ. Конверсия в регистрацию на демо-версию — не менее 8%.",
    whatSawAndDid: "Старый сайт содержал много сложного технического сленга, непонятного директорам по логистике. Мы переписали контент простым языком выгод: показали сколько часов и денег экономит платформа, добавили интерактивный калькулятор окупаемости и 3-секундный видео-разбор интерфейса.",
    result: "Конверсия страницы из холодного рекламного трафика составила 11.2% в регистрацию на тест-драйв. Стоимость привлечения лида (CPL) снизилась на 42% по сравнению с предыдущими тестами."
  }
];
---

<Layout title="Ульяна Кирпичникова | Разработка продающих сайтов под ключ">
  <Header />

  <main>
    {/* Block 1: Hero Section */}
    <section id="hero" class="hero-section section-padding">
      <div class="container hero-container-centered">
        <div class="hero-content-centered">

          <h1 class="hero-title text-center">
            Делаю сайты для бизнеса <br />
            как инструмент продаж
          </h1>
          
          <p class="hero-subtitle text-center">
            Нахожу смысловые ошибки в структуре, текстах и визуальной подаче, из-за которых вы теряете клиентов, и исправляю это. Делаю под ключ: от стратегии и аналитики до верстки и запуска.
          </p>

          <div class="hero-actions text-center">
            <a href="#discuss" class="btn btn-primary">Получить экспресс-аудит</a>
            <a href="#cases" class="btn btn-secondary">Смотреть проекты</a>
          </div>
        </div>

        {/* Wide Center Viewport Simulator with Floral Backdrop Wrapper */}
        <div class="simulator-outer-wrapper">
          <div class="hero-dashboard glass-card wide-viewport-card">
          {/* Float conversion badge (starts centered and in warning state) */}
          <div class="conversion-badge-float font-heading centered warning-state" id="conversion-badge">
            Конверсия: <span class="val">0.8%</span>
          </div>

          <div class="dashboard-header-bar">
            <div class="dashboard-dots">
              <span class="dot-red"></span>
              <span class="dot-yellow"></span>
              <span class="dot-green"></span>
            </div>
            <span class="dashboard-title font-heading">ventoved.ru</span>
            
            <span class="simulator-status-pill font-heading status-pill-error" id="simulator-status-pill">
              Ошибки в структуре и текстах
            </span>
          </div>
          
          <div class="viewport-frame" id="viewport-frame">

            {/* Simulated Website Layout */}
            <div class="simulated-website" id="simulated-website">
              
              {/* Mock Header/Navbar */}
              <div class="mock-navbar" id="mock-navbar">
                <div class="mock-logo font-heading">VENTOVED</div>
                <div class="mock-nav-links">
                  <span class="mock-nav-line"></span>
                  <span class="mock-nav-line"></span>
                  <span class="mock-nav-line"></span>
                </div>
                <div class="mock-nav-btn"></div>
              </div>

              {/* Block 1: Hero Section */}
              <div class="mock-hero-section" id="mock-hero">
                <div class="mock-hero-info">
                  <div class="mock-tag-indicator tag-error" id="hero-tag">Слабый оффер</div>
                  <h3 class="mock-title">Установка вентиляции</h3>
                  <p class="mock-desc">Динамично развивающаяся компания с индивидуальным подходом</p>
                  <div class="mock-hero-btn">Получить расчет</div>
                </div>
                <div class="mock-hero-graphic">
                  <div class="graphic-scheme">
                    <svg viewBox="0 0 100 60" fill="none" class="scheme-svg">
                      <rect x="5" y="5" width="90" height="50" rx="8" stroke="rgba(0,0,0,0.06)" stroke-width="1.5" stroke-dasharray="3 3"/>
                      <circle cx="50" cy="30" r="14" stroke="rgba(0,0,0,0.08)" stroke-width="1.5" fill="rgba(255,255,255,0.4)"/>
                      <path d="M15 30H36M64 30H85" stroke="rgba(0,0,0,0.08)" stroke-width="1.5" stroke-linecap="round"/>
                      <path class="scheme-flow-line" d="M15 30C25 30 30 15 50 15C70 15 75 30 85 30" stroke="var(--color-accent)" stroke-width="2.5" stroke-linecap="round"/>
                    </svg>
                    <span class="scheme-pulse"></span>
                  </div>
                </div>
              </div>

              {/* Block 2: Case block (starts below Hero, will be dragged up) */}
              <div class="mock-block-section mock-case-section" id="mock-case">
                <div class="section-drag-handle">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                    <circle cx="9" cy="5" r="1.5"/><circle cx="9" cy="12" r="1.5"/><circle cx="9" cy="19" r="1.5"/>
                    <circle cx="15" cy="5" r="1.5"/><circle cx="15" cy="12" r="1.5"/><circle cx="15" cy="19" r="1.5"/>
                  </svg>
                </div>
                <div class="mock-case-badge font-heading">Кейс</div>
                <div class="mock-case-body">
                  <h4 class="mock-case-title">Монтаж вентиляции в коттедже 180 м² за 4 дня</h4>
                  <p class="mock-case-result">Заявки на замер выросли в 3 раза за счет наглядности технических схем</p>
                </div>
              </div>

              {/* Block 3: Cards Section */}
              <div class="mock-cards-section" id="mock-cards">
                <div class="mock-card">
                  <div class="mock-card-icon">✦</div>
                  <div class="mock-card-title">Низкие цены</div>
                  <div class="mock-card-desc">Гибкая ценовая политика для всех</div>
                </div>
                <div class="mock-card">
                  <div class="mock-card-icon">✦</div>
                  <div class="mock-card-title">Быстрый монтаж</div>
                  <div class="mock-card-desc">Монтируем в кратчайшие сроки</div>
                </div>
                <div class="mock-card">
                  <div class="mock-card-icon">✦</div>
                  <div class="mock-card-title">Опыт 10 лет</div>
                  <div class="mock-card-desc">Профессиональная команда</div>
                </div>
              </div>

              {/* Block 4: CTA Lead Form (initially hidden/collapsed) */}
              <div class="mock-block-section mock-cta-section" id="mock-cta">
                <div class="mock-cta-content">
                  <h4 class="mock-cta-title">Рассчитайте стоимость вентиляции за 2 минуты</h4>
                  <div class="mock-cta-form-row">
                    <div class="mock-input-placeholder">Ваш телефон</div>
                    <div class="mock-btn-placeholder font-heading">Получить смету</div>
                  </div>
                </div>
              </div>

            </div>

            {/* Floating Hand Cursor */}
            <div class="hand-cursor" id="hand-cursor">
              <svg width="30" height="30" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <g filter="url(#hand-shadow)">
                  <path d="M12.5 12.5V5.5C12.5 4.67157 11.8284 4 11 4C10.1716 4 9.5 4.67157 9.5 5.5V12.5M12.5 12.5C13.0523 12.5 13.5 12.0523 13.5 11.5V7.5C13.5 6.67157 14.1716 6 15 6C15.8284 6 16.5 6.67157 16.5 7.5V11.5M12.5 12.5V13.5C12.5 15.433 10.933 17 9 17C7.067 17 5.5 15.433 5.5 13.5V10.5C5.5 9.67157 6.17157 9 7 9C7.82842 9 8.5 9.67157 8.5 10.5V12.5M16.5 11.5C17.0523 11.5 17.5 11.0523 17.5 10.5V8.5C17.5 7.67157 18.1716 7 19 7C19.8284 7 20.5 7.67157 20.5 8.5V13.5C20.5 17.0899 17.5899 20 14 20H12C8.68629 20 6 17.3137 6 14V13.5" stroke="#111827" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" fill="#ffffff"/>
                </g>
                <defs>
                  <filter id="hand-shadow" x="0" y="0" width="30" height="30" filterUnits="userSpaceOnUse">
                    <feDropShadow dx="1" dy="2" stdDeviation="1.5" flood-color="#000" flood-opacity="0.25"/>
                  </filter>
                </defs>
              </svg>
            </div>

            {/* Notification Stack on the bottom right */}
            <div class="notifications-stack" id="notifications-stack">
              {/* Notifications will be appended here dynamically via JavaScript */}
            </div>

          </div>
        </div>
      </div>



      </div>
    </section>

    {/* Block 2: С чем я могу помочь (Split Scroll) */}
    <section id="services" class="services-section section-padding">
      <ServicesScroll />
    </section>

    {/* CTA: Express Audit Block */}
    <section id="discuss" class="audit-section section-padding">
      <div class="container">
        <div class="glass-card audit-card">
          <div class="audit-grid">
            <div class="audit-left">
              <div class="audit-info">
                <h2 class="audit-title font-heading">Хотите посмотреть на сайт глазами клиента?</h2>
                <p class="audit-desc">
                  Пришлите ссылку на ваш сайт и я сделаю разбор без созвонов и долгих встреч. Узнаете, где именно вы теряете заявки и как исправить.
                </p>
              </div>
            </div>
            
            <div class="audit-right">
              <div class="form-wrapper">
                <form class="audit-form" id="auditForm">
                  <div class="form-group">
                    <label for="site-url" class="form-label">Ссылка на ваш сайт</label>
                    <input 
                      type="text" 
                      inputmode="url" 
                      id="site-url" 
                      name="siteUrl" 
                      class="form-input" 
                      placeholder="https://mysite.ru" 
                      required 
                    />
                  </div>
                  <div class="form-group">
                    <label for="contact" class="form-label">Куда прислать разбор (Telegram / WA / Email)</label>
                    <input 
                      type="text" 
                      id="contact" 
                      name="contact" 
                      class="form-input" 
                      placeholder="@telegram или +7..." 
                      required 
                    />
                  </div>
                  <button type="submit" class="btn btn-primary btn-submit-audit">
                    Отправить сайт на разбор
                  </button>
                  <div id="formStatus" class="form-status" aria-live="polite"></div>
                </form>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    {/* Block 3: Какие проекты делала (Кейсы) */}
    <section id="cases" class="cases-section section-padding">
      <div class="container">
        <div class="section-header">
          <h2 class="section-title">Какие проекты я делала</h2>
          <p class="section-intro">
            Я убеждена, что не все измеряется сухими конверсиями. Бизнес часто нанимает сайт для более глубоких задач: отсечь нецелевых клиентов, сэкономить время менеджеров на объяснения или выстроить статус компании.
          </p>
        </div>

        <div class="grid-2 cases-grid">
          {cases.map((project) => (
            <article class="glass-card case-card">
              <div class="case-header">
                <span class="case-tag">{project.niche}</span>
              </div>
              <h3 class="case-title">{project.title}</h3>
              
              <div class="case-meta">
                <div class="meta-section">
                  <h5>Задача бизнеса / Целевая метрика:</h5>
                  <p>{project.task}</p>
                </div>
                
                <div class="meta-section">
                  <h5>Что увидела и что сделала:</h5>
                  <p>{project.whatSawAndDid}</p>
                </div>

                <div class="meta-section result-section">
                  <h5>Результат:</h5>
                  <p class="highlight-result">{project.result}</p>
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    {/* Block 4 & 5: Отзывы и Манифест подход */}
    <section id="reviews" class="reviews-section section-padding">
      <div class="container">
        <h2 class="section-title text-center">Что говорят клиенты о работе со мной</h2>
        
        {/* Placeholder for video reviews or screenshots */}
        <div class="reviews-gallery grid-3">
          <div class="glass-card review-placeholder-card">
            <div class="video-overlay-icon">▶</div>
            <h5>Разбор B2B проекта</h5>
            <p>Отзыв основателя машиностроительного завода</p>
          </div>
          <div class="glass-card review-placeholder-card">
            <div class="video-overlay-icon">▶</div>
            <h5>Разбор SaaS сервиса</h5>
            <p>Отзыв маркетолога IT-компании</p>
          </div>
          <div class="glass-card review-placeholder-card">
            <div class="video-overlay-icon">▶</div>
            <h5>Быстрый запуск лендинга</h5>
            <p>Отзыв продюсера онлайн-школы</p>
          </div>
        </div>

        {/* Manifesto block */}
        <div class="manifesto-wrapper">
          <blockquote class="manifesto-quote">
            <p>
              «Если честно, отзывы — это хорошо. Но все мы разные. Для кого-то мой подход и то, как я работаю — это огонь и стопроцентное попадание. А кому-то вообще не зайдет мой стиль, моя стратегия и мой взгляд на продажи. На то, как думают клиенты и как они принимают решения.
            </p>
            <p>
              Поэтому самый надежный способ проверить, подходим ли мы друг другу — это познакомиться лично и обсудить именно ваш проект».
            </p>
          </blockquote>
        </div>

        {/* Block 5 CTA */}
        <div id="discuss-business" class="manifesto-cta glass-card">
          <div class="cta-inner">
            <h3>Поэтому давайте встречаться!</h3>
            <p>Мы созвонимся или спишемся, разберем ваши задачи и ваш бизнес. Посмотрим, как сайт может помочь в их решении и как правильно подготовить его к этой задаче.</p>
            <a href="https://t.me/UlyanaKir" target="_blank" rel="noopener noreferrer" class="btn btn-primary">
              Обсудить мой бизнес в Telegram
            </a>
          </div>
        </div>
      </div>
    </section>

    {/* Block 6: Pricing and formats */}
    <section id="pricing" class="pricing-section section-padding">
      <div class="container">
        <div class="section-header text-center">
          <h2 class="section-title">Форматы работы и цены</h2>
          <p class="section-intro" style="margin-inline: auto;">
            Я работаю в удобных b2b-форматах: от быстрых и детальных аудитов до полного проектирования сайта под ключ.
          </p>
        </div>

        <div class="pricing-group-wrapper" style="margin-block-end: 4rem;">
          <h3 class="pricing-group-title" style="font-family: var(--font-heading); font-size: 1.25rem; font-weight: 600; margin-block-end: 1.5rem; color: var(--color-text-secondary);">
            Анализ и оптимизация сайта (Быстрый старт)
          </h3>
          <div class="grid-2 pricing-grid">
            <div class="glass-card pricing-card">
              <span class="price-tag">Конверсия & UX</span>
              <h3 class="price-title">Аудит конверсии посадочной страницы</h3>
              <p class="price-desc">
                Поиск утечек конверсии, ошибок в позиционировании и барьеров перед отправкой заявки. Включает готовые варианты рерайта главного экрана и ТОП-10 приоритетных правок. Вы получаете готовый PDF-отчет за 48 часов.
              </p>
              <div class="price-value">15 000 ₽ <span style="font-size: 1.1rem; text-decoration: line-through; color: var(--color-text-muted); font-weight: normal; margin-left: 0.5rem;">25 000 ₽</span></div>
              <a href="/audit" class="btn btn-secondary">Подробнее об аудите</a>
            </div>

            <div class="glass-card pricing-card">
              <span class="price-tag">ИИ-оптимизация (GEO)</span>
              <h3 class="price-title">Аудит видимости сайта в ИИ-поисковиках</h3>
              <p class="price-desc">
                Проверка готовности сайта к выдачам в ChatGPT, Perplexity, Gemini. Анализ Schema.org-разметки, технических доступов для роботов и составление ТЗ для внедрения FAQ-блоков и сигналов доверия.
              </p>
              <div class="price-value">30 000 ₽ <span style="font-size: 1.1rem; text-decoration: line-through; color: var(--color-text-muted); font-weight: normal; margin-left: 0.5rem;">50 000 ₽</span></div>
              <a href="/ai-visibility-audit" class="btn btn-secondary">Подробнее об ИИ-аудите</a>
            </div>
          </div>
        </div>

        <div class="pricing-group-wrapper">
          <h3 class="pricing-group-title" style="font-family: var(--font-heading); font-size: 1.25rem; font-weight: 600; margin-block-end: 1.5rem; color: var(--color-text-secondary);">
            Проектирование и разработка под ключ
          </h3>
          <div class="grid-2 pricing-grid">
            <div class="glass-card pricing-card">
              <span class="price-tag">Концепт & Тексты</span>
              <h3 class="price-title">Смысловая структура и тексты под конверсию</h3>
              <p class="price-desc">
                Глубокий анализ продукта и аудитории, проектирование логики и написание всех продающих текстов. Вы получаете готовый интерактивный макет сайта, по которому ваша команда сможет запустить проект без потери смыслов.
              </p>
              <div class="price-value">от 80 000 ₽</div>
              <a href="#discuss" class="btn btn-secondary">Заказать структуру</a>
            </div>

            <div class="glass-card pricing-card popular">
              <div class="popular-badge">Под ключ</div>
              <span class="price-tag accent">Полная упаковка</span>
              <h3 class="price-title">Полная упаковка сайта под ключ</h3>
              <p class="price-desc">
                Полный цикл от интервью и аналитики до финального веб-дизайна, адаптивной верстки и запуска готового сайта на вашем домене. Я сама контролирую каждый пиксель, чтобы логика продаж не сломалась на этапе верстки.
              </p>
              <div class="price-value">от 150 000 ₽</div>
              <a href="#discuss" class="btn btn-primary">Заказать сайт под ключ</a>
            </div>
          </div>
        </div>
      </div>
    </section>

    {/* Block 7: Финальный CTA */}
    <section class="final-cta-section section-padding">
      <div class="container text-center">
        <h2 class="hero-title" style="font-size: var(--fs-h2); margin-block-end: 1rem; color: var(--color-text-primary);">
          Пересоберем ваш сайт под задачи бизнеса?
        </h2>
        <p style="max-inline-size: 600px; margin-inline: auto; margin-block-end: 2rem; color: var(--color-text-secondary);">
          Напишите мне. Мы начнем с короткого разбора, найдем точки роста и поймем, какой формат работы вам подходит.
        </p>
        <a href="https://t.me/UlyanaKir" target="_blank" rel="noopener noreferrer" class="btn btn-primary btn-lg">
          Начать работу с Ульяной
        </a>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  /* Hero Section */
  .hero-section {
    position: relative;
    padding-block-start: 130px;
    overflow: hidden;
  }

  .hero-container-centered {
    display: flex;
    flex-direction: column;
    gap: 4rem;
    align-items: center;
    width: 100%;
  }

  .hero-content-centered {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    max-inline-size: 1100px;
    width: 100%;
  }

  .text-center {
    text-align: center;
  }

  .hero-subtitle.text-center {
    margin-inline: auto;
    max-inline-size: 750px;
  }

  .hero-actions.text-center {
    justify-content: center;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    border-radius: var(--radius-default);
    background: var(--color-bg-subtle);
    border: 1px solid var(--color-border);
    font-size: 0.975rem;
    font-weight: 500;
  }

  .hero-title {
    font-size: var(--fs-h1);
    letter-spacing: -1.5px;
    color: var(--color-text-primary);
  }

  .hero-subtitle {
    font-size: clamp(1.05rem, 1rem + 0.3vw, 1.25rem);
    line-height: 1.55;
    margin-block-end: 1rem;
    color: var(--color-text-secondary);
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }

  /* Widescreen Dashboard Wrapper & Styling */
  .simulator-outer-wrapper {
    width: 100%;
    margin: 3rem auto 0 auto;
    padding: 3.5rem 4rem;
    border-radius: 28px;
    background-image: linear-gradient(to bottom, rgba(10, 20, 70, 0.12) 0%, rgba(5, 12, 45, 0.2) 100%), url('/simulator_backdrop.png');
    background-size: cover;
    background-position: center top;
    box-shadow: 0 30px 80px rgba(5, 15, 60, 0.45);
    border: none;
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2.5rem;
    justify-content: center;
  }

  @media (max-width: 991px) {
    .simulator-outer-wrapper {
      padding: 2.5rem 1.5rem;
      border-radius: 20px;
      margin-top: 2rem;
      gap: 2rem;
    }
  }

  @media (max-width: 575px) {
    .simulator-outer-wrapper {
      padding: 1.75rem 0.75rem;
      border-radius: 16px;
      gap: 1.5rem;
    }
  }

  /* Wide Center Viewport Simulator CSS */
  .wide-viewport-card {
    width: 100% !important;
    max-width: 840px;
    margin: 0 auto;
    padding: 0;
  }

  .hero-dashboard {
    width: 100%;
    background: rgba(255, 255, 255, 0.55);
    backdrop-filter: blur(20px) saturate(140%);
    -webkit-backdrop-filter: blur(20px) saturate(140%);
    border: 1px solid rgba(255, 255, 255, 0.6);
    padding: 0;
    box-shadow: 
      0 30px 70px rgba(5, 12, 45, 0.15),
      0 0 40px rgba(157, 255, 32, 0.08);
    border-radius: 16px;
    overflow: hidden;
    position: relative;
  }

  .dashboard-header-bar {
    position: relative;
    display: flex;
    align-items: center;
    background: rgba(255, 255, 255, 0.65);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    padding: 0.75rem 1.5rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.4);
    height: 45px;
  }

  @media (max-width: 575px) {
    .dashboard-header-bar {
      padding: 0.6rem 1.15rem;
    }
    .dashboard-title {
      display: none;
    }
    .simulator-status-pill {
      margin-left: 0;
    }
  }

  .dashboard-dots {
    display: flex;
    gap: 6px;
  }

  .dashboard-dots span {
    width: 8px;
    height: 8px;
    border-radius: 50%;
  }
  .dashboard-dots .dot-red { background-color: #ef4444; }
  .dashboard-dots .dot-yellow { background-color: #f59e0b; }
  .dashboard-dots .dot-green { background-color: #10b981; }

  .dashboard-title {
    font-size: 0.8rem;
    color: var(--color-text-secondary);
    margin-left: 1.5rem;
    letter-spacing: 0.2px;
    font-weight: 500;
  }

  /* Status Pill Styles in Header Bar */
  .simulator-status-pill {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    margin-left: 0;
    font-size: 0.7rem;
    font-weight: 600;
    padding: 0.25rem 0.75rem;
    border-radius: 9999px;
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    display: inline-flex;
    align-items: center;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }
  
  .status-pill-error {
    background: rgba(255, 75, 75, 0.1);
    border: 1px solid rgba(255, 75, 75, 0.25);
    color: #FF4B4B;
    box-shadow: 0 0 10px rgba(255, 75, 75, 0.05);
  }
  
  .status-pill-process {
    background: rgba(245, 158, 11, 0.1);
    border: 1px solid rgba(245, 158, 11, 0.25);
    color: #d97706;
    box-shadow: 0 0 10px rgba(245, 158, 11, 0.05);
  }
  
  .status-pill-success {
    background: rgba(157, 255, 32, 0.1);
    border: 1px solid rgba(157, 255, 32, 0.3);
    color: #1A7F00;
    box-shadow: 0 0 15px rgba(157, 255, 32, 0.15);
  }

  .conversion-badge-float {
    position: absolute;
    border-radius: 9999px;
    font-weight: 600;
    transition: all 0.8s cubic-bezier(0.25, 1, 0.25, 1.15);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
  }

  .conversion-badge-float.centered {
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%) scale(2.2);
    font-size: 1.1rem;
    padding: 0.75rem 1.75rem;
    z-index: 100;
  }

  .conversion-badge-float.docked {
    top: 12px;
    right: 24px;
    transform: translate(0, 0) scale(1);
    font-size: 0.8rem;
    padding: 0.4rem 1.1rem;
    z-index: 10;
  }

  .conversion-badge-float.warning-state {
    background: rgba(255, 255, 255, 0.95);
    border: 2px solid rgba(255, 75, 75, 0.4);
    color: #FF4B4B;
    box-shadow: 0 10px 30px rgba(255, 75, 75, 0.15);
  }

  .conversion-badge-float.success-state {
    background: rgba(255, 255, 255, 0.95);
    border: 2px solid var(--color-accent);
    color: #1A7F00;
    box-shadow: 0 15px 40px rgba(157, 255, 32, 0.3), 0 0 20px rgba(157, 255, 32, 0.15);
  }

  .hand-cursor {
    position: absolute;
    z-index: 110;
    pointer-events: none;
    transition: left 0.8s cubic-bezier(0.25, 1, 0.5, 1), top 0.8s cubic-bezier(0.25, 1, 0.5, 1), transform 0.2s ease, opacity 0.4s ease;
    opacity: 0;
    transform: scale(1);
    left: 85%;
    top: 80%;
  }

  .hand-cursor.clicking {
    transform: scale(0.85);
  }

  .hand-cursor.grabbing {
    transform: scale(0.95) rotate(-5deg);
  }

  .viewport-frame {
    height: 520px;
    width: 100%;
    background: radial-gradient(circle at center, rgba(157, 255, 32, 0.03) 0%, rgba(248, 250, 252, 0.85) 100%);
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    border-bottom-left-radius: 16px;
    border-bottom-right-radius: 16px;
  }

  .simulated-website {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding: 1rem 1.5rem;
    width: 100%;
    max-width: 780px;
    margin: 0 auto;
    position: relative;
  }

  /* Flexbox order sorting */
  #mock-navbar { order: 0; }
  #mock-hero { order: 1; }
  #mock-cards { order: 2; }
  #mock-case { order: 3; }
  #mock-cta { order: 4; }

  .simulated-website.reordered #mock-case {
    order: 2;
  }

  .simulated-website.reordered #mock-cards {
    order: 3;
  }

  /* Mock Navbar */
  .mock-navbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid rgba(0, 0, 0, 0.05);
    margin-bottom: 0.25rem;
  }

  .mock-logo {
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 1px;
    color: var(--color-text-primary);
  }

  .mock-nav-links {
    display: flex;
    gap: 0.75rem;
  }

  .mock-nav-line {
    width: 25px;
    height: 3px;
    background: rgba(0, 0, 0, 0.06);
    border-radius: 2px;
  }

  .mock-nav-btn {
    width: 50px;
    height: 16px;
    background: rgba(0, 0, 0, 0.05);
    border-radius: 4px;
  }

  /* Mock Hero Section */
  .mock-hero-section {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 1.5rem;
    background: rgba(255, 255, 255, 0.65);
    border: 1px solid rgba(255, 255, 255, 0.7);
    padding: 1rem 1.25rem;
    border-radius: 12px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.02);
    transition: all 0.4s ease;
  }

  .mock-hero-info {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    align-items: flex-start;
  }

  .mock-title {
    font-size: 1.15rem;
    font-weight: 700;
    line-height: 1.25;
    margin: 0;
    color: var(--color-text-primary);
    position: relative;
    transition: color 0.3s ease;
  }

  .mock-desc {
    font-size: 0.78rem;
    color: var(--color-text-secondary);
    line-height: 1.4;
    margin: 0;
    max-width: 90%;
    transition: color 0.3s ease;
  }

  .mock-hero-btn {
    font-size: 0.72rem;
    font-weight: 600;
    padding: 0.35rem 0.85rem;
    background: rgba(0, 0, 0, 0.05);
    color: var(--color-text-primary);
    border-radius: 6px;
    margin-top: 0.25rem;
    transition: all 0.3s ease;
  }

  .optimized-mode .mock-hero-btn {
    background: #6EDB00;
    color: #000;
    box-shadow: 0 0 10px rgba(157, 255, 32, 0.3);
  }

  .mock-hero-graphic {
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0, 0, 0, 0.02);
    border: 1px solid rgba(0, 0, 0, 0.03);
    border-radius: 8px;
    padding: 0.5rem;
    position: relative;
    overflow: hidden;
  }

  .graphic-scheme {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .scheme-svg {
    width: 100%;
    max-height: 70px;
  }

  .scheme-pulse {
    position: absolute;
    width: 6px;
    height: 6px;
    background: var(--color-accent);
    border-radius: 50%;
    top: 25%;
    left: 15%;
    opacity: 0;
    box-shadow: 0 0 8px var(--color-accent);
  }

  .optimized-mode .scheme-pulse {
    animation: flow-pulse 2s infinite linear;
  }

  @keyframes flow-pulse {
    0% { left: 15%; top: 50%; opacity: 0; }
    10% { opacity: 1; }
    50% { left: 50%; top: 25%; }
    90% { opacity: 1; }
    100% { left: 85%; top: 50%; opacity: 0; }
  }

  .optimized-mode .scheme-flow-line {
    stroke: var(--color-accent);
    opacity: 0.7 !important;
    stroke-dasharray: 5 3;
    animation: flow-dash 10s infinite linear;
  }

  @keyframes flow-dash {
    to { stroke-dashoffset: -100; }
  }

  /* Mock Tag Indicator */
  .mock-tag-indicator {
    font-size: 0.6rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 2px 6px;
    border-radius: 4px;
    margin-bottom: 0.15rem;
    transition: all 0.3s ease;
  }

  .tag-error {
    background: rgba(255, 75, 75, 0.1);
    border: 1px solid rgba(255, 75, 75, 0.2);
    color: #FF4B4B;
  }

  .tag-success {
    background: rgba(157, 255, 32, 0.15);
    border: 1px solid rgba(157, 255, 32, 0.3);
    color: #1A7F00;
  }

  /* Mock Case Block */
  .mock-case-section {
    display: flex;
    align-items: center;
    gap: 1rem;
    background: rgba(255, 255, 255, 0.65);
    border: 1px solid rgba(0, 0, 0, 0.05);
    padding: 0.75rem 1rem;
    border-radius: 12px;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.01);
    position: relative;
    transition: transform 0.8s cubic-bezier(0.25, 1, 0.5, 1), border-color 0.4s, background-color 0.4s, box-shadow 0.4s;
  }

  .section-drag-handle {
    cursor: grab;
    color: rgba(0, 0, 0, 0.2);
    display: flex;
    align-items: center;
  }

  .mock-case-badge {
    font-size: 0.62rem;
    font-weight: 600;
    text-transform: uppercase;
    background: rgba(0, 0, 0, 0.05);
    padding: 2px 6px;
    border-radius: 4px;
    color: var(--color-text-secondary);
    transition: all 0.3s ease;
  }

  .mock-case-body {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .mock-case-title {
    font-size: 0.85rem;
    font-weight: 600;
    margin: 0;
    color: var(--color-text-primary);
  }

  .mock-case-result {
    font-size: 0.75rem;
    color: var(--color-text-secondary);
    margin: 0;
    transition: color 0.3s ease;
  }

  .optimized-mode .mock-case-result {
    color: #1A7F00;
    font-weight: 600;
  }

  .optimized-mode .mock-case-section {
    border-color: rgba(157, 255, 32, 0.3);
    box-shadow: 0 0 15px rgba(157, 255, 32, 0.08);
  }

  .optimized-mode .mock-case-badge {
    background: rgba(157, 255, 32, 0.2);
    color: #1A7F00;
  }

  /* Smooth drag animations */
  #mock-case.dragging {
    z-index: 10;
    box-shadow: 0 15px 35px rgba(0, 0, 0, 0.1), 0 0 15px rgba(157, 255, 32, 0.15);
    transform: translateY(-90px);
    border-color: rgba(157, 255, 32, 0.4);
  }

  #mock-cards.shifted-down {
    transform: translateY(75px);
  }

  /* Mock Cards */
  .mock-cards-section {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.75rem;
    transition: transform 0.8s cubic-bezier(0.25, 1, 0.5, 1);
  }

  .mock-card {
    background: rgba(255, 255, 255, 0.55);
    border: 1px solid rgba(0, 0, 0, 0.04);
    padding: 0.75rem;
    border-radius: 10px;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    transition: all 0.4s ease;
  }

  .mock-card-icon {
    font-size: 0.75rem;
    color: rgba(0, 0, 0, 0.2);
    transition: color 0.3s;
  }

  .mock-card-title {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-text-primary);
  }

  .mock-card-desc {
    font-size: 0.7rem;
    color: var(--color-text-secondary);
    line-height: 1.3;
  }

  .optimized-mode .mock-card {
    border-color: rgba(157, 255, 32, 0.2);
    background: rgba(255, 255, 255, 0.75);
    box-shadow: 0 4px 12px rgba(157, 255, 32, 0.04);
  }

  .optimized-mode .mock-card-icon {
    color: var(--color-accent);
  }

  /* Mock CTA Section */
  .mock-cta-section {
    background: linear-gradient(135deg, rgba(255,255,255,0.7) 0%, rgba(240,250,230,0.6) 100%);
    border: 1px dashed rgba(157, 255, 32, 0.3);
    padding: 0;
    border-radius: 12px;
    height: 0;
    opacity: 0;
    overflow: hidden;
    transition: all 0.5s cubic-bezier(0.25, 1, 0.5, 1);
  }

  .mock-cta-section.visible {
    padding: 0.85rem 1.25rem;
    height: auto;
    opacity: 1;
    border-style: solid;
  }

  .mock-cta-content {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
  }

  .mock-cta-title {
    font-size: 0.82rem;
    font-weight: 600;
    margin: 0;
    color: var(--color-text-primary);
  }

  .mock-cta-form-row {
    display: flex;
    gap: 0.5rem;
    align-items: center;
  }

  .mock-input-placeholder {
    font-size: 0.7rem;
    color: var(--color-text-muted);
    padding: 0.35rem 0.6rem;
    border: 1px solid rgba(0, 0, 0, 0.08);
    background: #fff;
    border-radius: 6px;
    width: 100px;
  }

  .mock-btn-placeholder {
    font-size: 0.7rem;
    font-weight: 600;
    color: #000;
    background: #6EDB00;
    padding: 0.35rem 0.8rem;
    border-radius: 6px;
    box-shadow: 0 0 10px rgba(157, 255, 32, 0.25);
  }

  /* Typing Caret */
  .typing-active::after {
    content: '|';
    color: var(--color-accent);
    font-weight: 400;
    animation: caret-blink 0.8s infinite;
    margin-left: 2px;
    display: inline-block;
  }

  @keyframes caret-blink {
    50% { opacity: 0; }
  }


  /* Global Notifications Stack styling (prevents Astro scoped CSS issue) */
  :global(.notifications-stack) {
    position: absolute;
    bottom: 1.5rem;
    right: 1.5rem;
    display: flex;
    flex-direction: column-reverse; /* Stack upward */
    gap: 0.65rem;
    z-index: 120;
    width: 340px;
    max-height: 85%;
    overflow: visible;
    pointer-events: none;
    
    @media (max-width: 767px) {
      width: calc(100% - 2rem);
      bottom: 1rem;
      right: 1rem;
      left: 1rem;
      max-height: 70%;
    }
  }

  /* Premium glassmorphic notifications with soft shadow */
  :global(.lead-notification) {
    background-color: rgba(255, 255, 255, 0.65) !important;
    backdrop-filter: blur(16px) saturate(140%) !important;
    -webkit-backdrop-filter: blur(16px) saturate(140%) !important;
    border: 1px solid rgba(157, 255, 32, 0.25) !important;
    border-radius: 12px !important;
    padding: 0.75rem 1rem !important;
    display: flex !important;
    align-items: center !important;
    gap: 0.75rem !important;
    opacity: 0;
    transform: translateY(20px) scale(0.95);
    transition: transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275), opacity 0.4s;
    box-shadow: 
      0 10px 25px rgba(0, 0, 0, 0.05),
      0 0 20px rgba(157, 255, 32, 0.15) !important;
    color: var(--color-text-primary) !important;
    z-index: 10 !important;
    position: relative !important;
    width: 100% !important;
    box-sizing: border-box !important;
    
    @media (max-width: 767px) {
      padding: 0.6rem 0.8rem !important;
    }
  }

  :global(.lead-notification.visible) {
    opacity: 1 !important;
    transform: translateY(0) scale(1) !important;
  }

  :global(.lead-icon-svg) {
    animation: bell-ring-shake 0.6s ease;
    flex-shrink: 0 !important;
  }

  @keyframes bell-ring-shake {
    0%, 100% { transform: rotate(0); }
    15% { transform: rotate(20deg); }
    30% { transform: rotate(-15deg); }
    45% { transform: rotate(10deg); }
    60% { transform: rotate(-8deg); }
    75% { transform: rotate(4deg); }
  }

  :global(.lead-info-text) {
    display: flex !important;
    flex-direction: column !important;
    gap: 0.2rem !important;
    text-align: left !important;
  }

  :global(.lead-title-txt) {
    font-size: 0.85rem !important;
    font-weight: 700 !important;
    color: var(--color-text-primary) !important;
    margin: 0 !important;
    line-height: 1.2 !important;
    font-family: var(--font-body) !important;
  }

  :global(.lead-contact-txt) {
    font-size: 0.75rem !important;
    color: #64748b !important;
    font-family: var(--font-body) !important;
    font-weight: 500 !important;
    margin: 0 !important;
  }

  .review-placeholder-card {
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    gap: 0.75rem;
    cursor: pointer;
  }

  .video-overlay-icon {
    width: 50px;
    height: 50px;
    background: var(--color-bg);
    border: 1px solid var(--color-text-primary);
    border-radius: var(--radius-default);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.2rem;
    color: var(--color-text-primary);
    transition: transform 0.2s ease, background-color 0.2s, color 0.2s, border-color 0.2s;
  }

  .review-placeholder-card:hover .video-overlay-icon {
    transform: scale(1.05);
    background-color: var(--color-accent);
    color: #1a1a1a;
    border-color: var(--color-accent);
  }

  .manifesto-wrapper {
    max-inline-size: 800px;
    margin-inline: auto;
    margin-block-end: 4rem;
  }

  .manifesto-quote {
    border-left: 1px solid var(--color-text-primary);
    padding-left: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .manifesto-quote p {
    font-family: var(--font-heading);
    font-size: clamp(1.15rem, 1rem + 1vw, 1.4rem);
    line-height: 1.5;
    color: var(--color-text-primary);
    font-style: italic;
    font-weight: 500;
  }

  .manifesto-cta {
    max-inline-size: 800px;
    margin-inline: auto;
    text-align: center;
    border-color: var(--color-border);
  }

  .cta-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }

  .cta-inner h3 {
    font-size: var(--fs-h3);
    color: var(--color-text-primary);
  }

  .cta-inner p {
    max-inline-size: 550px;
    color: var(--color-text-secondary);
  }

  /* Pricing Section */
  .pricing-grid {
    gap: 2.5rem;
    align-items: stretch;
  }

  .pricing-card {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    height: 100%;
    gap: 1.5rem;
  }

  .pricing-card.popular {
    border-color: var(--color-accent);
    border-width: 1px;
    box-shadow: none !important;
  }

  .popular-badge {
    position: absolute;
    top: 1.5rem;
    right: 1.5rem;
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    background: var(--color-accent);
    color: #1a1a1a;
    padding: 0.3rem 0.6rem;
    border-radius: var(--radius-default);
  }

  .price-tag {
    font-size: 0.9rem;
    font-weight: 500;
    text-transform: uppercase;
    color: var(--color-text-muted);
    letter-spacing: 0.5px;
  }

  .price-tag.accent {
    color: var(--color-text-primary);
  }

  .price-title {
    font-size: var(--fs-h3);
    color: var(--color-text-primary);
  }

  .price-desc {
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--color-text-secondary);
    flex-grow: 1;
  }

  .price-value {
    font-family: var(--font-heading);
    font-size: 2.2rem;
    font-weight: 500;
    color: var(--color-text-primary);
  }

  /* Keyframe Animations */
  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  @keyframes bar-grow {
    from { height: 10%; }
    to { height: 100%; }
  }

  /* Audit Section / Express Audit Redesign */
  .audit-section {
    position: relative;
    overflow: hidden;
  }

  .audit-card {
    padding: 4.5rem 5rem;
    background-color: rgba(255, 255, 255, 0.45);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: none !important;
    transition: border-color 0.3s ease, background-color 0.3s ease;
    overflow: visible;
  }

  .audit-card:hover {
    border: none !important;
    background-color: rgba(255, 255, 255, 0.6) !important;
  }

  .audit-grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 5rem;
    align-items: flex-start;
  }

  .audit-left {
    display: flex;
    flex-direction: column;
    gap: 3.5rem;
  }

  .audit-info {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }



  .audit-title {
    font-size: var(--fs-h2);
    font-weight: normal;
    color: var(--color-text-primary);
    line-height: 1.2;
    margin: 0;
  }

  .audit-desc {
    font-size: 1.05rem;
    line-height: 1.6;
    color: var(--color-text-secondary);
    margin: 0;
  }

  /* Form Spacing & Hierarchy */
  .audit-right {
    background: transparent;
  }

  .form-wrapper {
    display: flex;
    flex-direction: column;
    gap: 2.25rem;
  }

  .form-title {
    font-size: 1.6rem;
    font-weight: normal;
    color: var(--color-text-primary);
    margin: 0;
  }

  .audit-form {
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    position: relative;
  }

  .form-label {
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--color-text-secondary);
    transition: color 0.2s ease;
  }

  /* Style parent with :has to highlight label on focus */
  .form-group:has(.form-input:focus) .form-label {
    color: var(--color-text-primary);
  }

  .form-input {
    width: 100%;
    padding: 0.95rem 1.15rem;
    background: rgba(255, 255, 255, 0.7);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-default);
    color: var(--color-text-primary);
    font-size: 1.05rem;
    transition: all 0.25s cubic-bezier(0.16, 1, 0.3, 1);
    box-shadow: inset 0 2px 4px rgba(0, 0, 0, 0.02);
  }

  .form-input:hover {
    border-color: var(--color-text-primary);
    background: rgba(255, 255, 255, 0.9);
  }

  .form-input:focus {
    outline: none;
    border-color: var(--color-text-primary);
    background: #ffffff;
    box-shadow: 0 0 0 3px rgba(157, 255, 32, 0.25);
  }

  /* Form Interactive States - using Baseline :user-valid and :user-invalid */
  .form-input:user-invalid {
    border-color: #d93025;
    background-color: rgba(217, 48, 37, 0.02);
  }

  .form-input:user-invalid:focus {
    box-shadow: 0 0 0 3px rgba(217, 48, 37, 0.15);
  }

  .form-input:user-valid {
    border-color: #188038;
    background-color: rgba(24, 128, 56, 0.01);
  }

  .form-input:user-valid:focus {
    box-shadow: 0 0 0 3px rgba(24, 128, 56, 0.15);
  }

  /* Submit Button placement matching Design System */
  .btn-submit-audit {
    margin-block-start: 1rem;
    width: 100%;
  }

  /* Status message styles */
  .form-status {
    font-size: 0.95rem;
    font-weight: 500;
    padding: 0.75rem 1rem;
    border-radius: 4px;
    display: none;
    line-height: 1.4;
  }

  .form-status.success {
    display: block;
    background-color: rgba(24, 128, 56, 0.08);
    border: 1px solid rgba(24, 128, 56, 0.2);
    color: #188038;
  }

  .form-status.error {
    display: block;
    background-color: rgba(217, 48, 37, 0.08);
    border: 1px solid rgba(217, 48, 37, 0.2);
    color: #d93025;
  }

  /* Responsive styling for tablet and mobile */
  @media (max-width: 1024px) {
    .audit-card {
      padding: 3.5rem 3rem;
    }

    .audit-grid {
      gap: 3.5rem;
    }
  }

  @media (max-width: 768px) {
    .audit-card {
      padding: 3rem 2rem;
    }

    .audit-grid {
      grid-template-columns: 1fr;
      gap: 4rem;
    }

    .audit-left {
      gap: 2.5rem;
    }

    .form-wrapper {
      gap: 1.75rem;
    }
  }

  @media (max-width: 480px) {
    .audit-card {
      padding: 2.25rem 1.25rem;
    }

    .audit-title {
      font-size: 1.75rem;
    }

    .audit-desc {
      font-size: 0.95rem;
    }

    .form-title {
      font-size: 1.4rem;
    }
  }
</style>

<script>
  import { GOOGLE_SCRIPT_URL } from '../config';

  const handleForm = () => {
    const form = document.getElementById('auditForm') as HTMLFormElement;
    const status = document.getElementById('formStatus');
    
    if (form && status) {
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        
        status.textContent = "Отправка...";
        status.className = "form-status";
        
        if (!GOOGLE_SCRIPT_URL) {
          // Имитация отправки при пустом URL
          setTimeout(() => {
            status.textContent = "Спасибо! Ссылка отправлена на разбор (Имитация). Настройте GOOGLE_SCRIPT_URL в src/config.ts для реальной отправки.";
            status.className = "form-status success";
            form.reset();
          }, 1200);
          return;
        }

        try {
          const params = new URLSearchParams();
          const formData = new FormData(form);
          for (const [key, value] of formData.entries()) {
            params.append(key, value);
          }
          params.append('source', 'Экспресс-аудит (Главная)');

          await fetch(GOOGLE_SCRIPT_URL, {
            method: 'POST',
            mode: 'no-cors',
            headers: {
              'Content-Type': 'application/x-www-form-urlencoded'
            },
            body: params.toString()
          });

          status.textContent = "Спасибо! Ссылка отправлена на разбор. Я свяжусь с вами в ближайшее время.";
          status.className = "form-status success";
          form.reset();
        } catch (err) {
          console.error(err);
          status.textContent = "Ошибка при отправке. Пожалуйста, попробуйте написать мне в Telegram.";
          status.className = "form-status error";
          status.style.color = '#f85149';
        }
      });
    }
  };

  const handleSiteTransformation = () => {
    const container = document.querySelector('.wide-viewport-card') as HTMLElement;
    if (!container) return;

    const viewport = document.getElementById('viewport-frame') as HTMLElement;
    const simulatedWebsite = document.getElementById('simulated-website') as HTMLElement;
    const badge = document.getElementById('conversion-badge') as HTMLElement;
    const cursor = document.getElementById('hand-cursor') as HTMLElement;
    const notifStack = document.getElementById('notifications-stack') as HTMLElement;
    const statusPill = document.getElementById('simulator-status-pill') as HTMLElement;

    let timeouts: any[] = [];
    let isRunning = false;
    let hasRunOnce = false;

    const clearTimeouts = () => {
      timeouts.forEach(t => clearTimeout(t));
      timeouts = [];
    };

    const updateStatusPill = (text: string, stateClass: 'status-pill-error' | 'status-pill-process' | 'status-pill-success') => {
      if (!statusPill) return;
      statusPill.textContent = text;
      statusPill.className = `simulator-status-pill font-heading ${stateClass}`;
    };

    const resetSimulator = () => {
      clearTimeouts();
      isRunning = false;

      // Reset DOM states
      if (viewport) {
        viewport.classList.remove('optimized-mode');
      }
      if (simulatedWebsite) {
        simulatedWebsite.classList.remove('reordered');
      }
      if (badge) {
        badge.className = "conversion-badge-float font-heading centered warning-state";
        const valSpan = badge.querySelector('.val');
        if (valSpan) valSpan.textContent = '0.8%';
      }
      if (cursor) {
        cursor.style.opacity = "0";
        cursor.style.left = "85%";
        cursor.style.top = "80%";
        cursor.className = "hand-cursor";
      }
      const ctaSection = document.getElementById('mock-cta');
      if (ctaSection) {
        ctaSection.classList.remove('visible');
      }
      if (notifStack) {
        notifStack.innerHTML = '';
      }
      updateStatusPill("Ошибки в структуре и текстах", "status-pill-error");

      // Reset texts
      const titleEl = document.querySelector('.mock-title') as HTMLElement;
      if (titleEl) titleEl.textContent = "Установка вентиляции";

      const descEl = document.querySelector('.mock-desc') as HTMLElement;
      if (descEl) descEl.textContent = "Динамично развивающаяся компания с индивидуальным подходом";

      const heroTag = document.getElementById('hero-tag');
      if (heroTag) {
        heroTag.textContent = "Слабый оффер";
        heroTag.className = "mock-tag-indicator tag-error";
      }
    };

    const moveCursor = (left: string, top: string, clickAction = false, grabAction = false) => {
      return new Promise<void>((resolve) => {
        if (!cursor) { resolve(); return; }
        cursor.style.opacity = "1";
        cursor.style.left = left;
        cursor.style.top = top;
        
        if (clickAction) {
          cursor.classList.add('clicking');
          setTimeout(() => {
            cursor.classList.remove('clicking');
          }, 300);
        }
        
        if (grabAction) {
          cursor.classList.add('grabbing');
        } else {
          cursor.classList.remove('grabbing');
        }
        
        const t = setTimeout(resolve, 800);
        timeouts.push(t);
      });
    };

    const typeText = (element: HTMLElement, targetText: string, speed = 20) => {
      return new Promise<void>((resolve) => {
        element.textContent = "";
        element.classList.add('typing-active');
        let index = 0;
        const interval = setInterval(() => {
          element.textContent += targetText[index];
          index++;
          if (index >= targetText.length) {
            clearInterval(interval);
            element.classList.remove('typing-active');
            resolve();
          }
        }, speed);
        timeouts.push(interval);
      });
    };

    const animatePercentage = (startVal: number, endVal: number, duration: number) => {
      const valSpan = badge ? badge.querySelector('.val') : null;
      if (!valSpan) return;

      const steps = 40;
      const stepDuration = duration / steps;
      const stepIncrement = (endVal - startVal) / steps;
      let currentVal = startVal;
      let stepCount = 0;

      const countUp = () => {
        if (!isRunning) return;
        currentVal += stepIncrement;
        stepCount++;

        if (stepCount >= steps) {
          valSpan.textContent = endVal.toFixed(1) + '%';
          if (endVal > 10.0) {
            badge.classList.remove('warning-state');
            badge.classList.add('success-state');
          }
        } else {
          valSpan.textContent = currentVal.toFixed(1) + '%';
          if (currentVal > 5.0 && badge.classList.contains('warning-state')) {
            badge.classList.remove('warning-state');
            badge.classList.add('success-state');
          }
          const t = setTimeout(countUp, stepDuration);
          timeouts.push(t);
        }
      };

      countUp();
    };

    const addLeadNotification = (title: string, contact: string) => {
      if (!notifStack) return;
      const notif = document.createElement('div');
      notif.className = 'lead-notification';
      notif.innerHTML = `
        <svg class="lead-icon-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="width: 20px; height: 20px; flex-shrink: 0; stroke: #1A7F00; animation: bell-ring-shake 0.6s ease;">
          <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"></path>
          <path d="M13.73 21a2 2 0 0 1-3.46 0"></path>
        </svg>
        <div class="lead-info-text">
          <span class="lead-title-txt">${title}</span>
          <span class="lead-contact-txt">Контакт: ${contact}</span>
        </div>
      `;
      notifStack.appendChild(notif);
      setTimeout(() => notif.classList.add('visible'), 50);
    };

    const runTimeline = async () => {
      resetSimulator();
      isRunning = true;

      // Wait 1.2s before starting cursor actions
      await new Promise(r => {
        const t = setTimeout(r, 1200);
        timeouts.push(t);
      });
      if (!isRunning) return;

      // --- STEP 1: EDIT TITLE ---
      updateStatusPill("Оптимизация текстов", "status-pill-process");
      await moveCursor("22%", "16%"); // Move to title
      if (!isRunning) return;

      // Click
      if (cursor) cursor.classList.add('clicking');
      await new Promise(r => {
        const t = setTimeout(r, 200);
        timeouts.push(t);
      });
      if (cursor) cursor.classList.remove('clicking');

      const titleEl = document.querySelector('.mock-title') as HTMLElement;
      if (titleEl) {
        await typeText(titleEl, "Вентиляция в квартиры и дома под ключ", 12);
      }
      if (!isRunning) return;

      // --- STEP 2: EDIT DESCRIPTION ---
      await moveCursor("22%", "24%"); // Move to description
      if (!isRunning) return;

      // Click
      if (cursor) cursor.classList.add('clicking');
      await new Promise(r => {
        const t = setTimeout(r, 200);
        timeouts.push(t);
      });
      if (cursor) cursor.classList.remove('clicking');

      const descEl = document.querySelector('.mock-desc') as HTMLElement;
      if (descEl) {
        await typeText(descEl, "Проектирование и монтаж за 3 дня с чистой уборкой", 10);
      }
      if (!isRunning) return;

      // Update badge tag
      const heroTag = document.getElementById('hero-tag');
      if (heroTag) {
        heroTag.textContent = "Ценностный оффер";
        heroTag.className = "mock-tag-indicator tag-success";
      }

      // First Conversion Boost
      animatePercentage(0.8, 4.2, 800);

      await new Promise(r => {
        const t = setTimeout(r, 800);
        timeouts.push(t);
      });
      if (!isRunning) return;

      // --- STEP 3: REARRANGE BLOCKS (DRAG CASE BLOCK UPWARDS) ---
      updateStatusPill("Оптимизация структуры", "status-pill-process");

      const caseSection = document.getElementById('mock-case');
      const cardsSection = document.getElementById('mock-cards');

      // Move to Case Block drag handle
      await moveCursor("10%", "52%");
      if (!isRunning) return;

      // Grab Case Block
      if (cursor) cursor.classList.add('grabbing');
      if (caseSection) caseSection.classList.add('dragging');
      if (cardsSection) cardsSection.classList.add('shifted-down');

      await new Promise(r => {
        const t = setTimeout(r, 400);
        timeouts.push(t);
      });
      if (!isRunning) return;

      // Drag Case Block upwards
      await moveCursor("10%", "36%");
      if (!isRunning) return;

      // Drop block: swap order in DOM via classes
      if (cursor) cursor.classList.remove('grabbing');
      if (caseSection) caseSection.classList.remove('dragging');
      if (cardsSection) cardsSection.classList.remove('shifted-down');
      if (simulatedWebsite) simulatedWebsite.classList.add('reordered');

      // Second Conversion Boost
      animatePercentage(4.2, 8.5, 800);

      await new Promise(r => {
        const t = setTimeout(r, 800);
        timeouts.push(t);
      });
      if (!isRunning) return;

      // --- STEP 4: ADD NEW BLOCK (CTA LEAD FORM) ---
      updateStatusPill("Добавление целевых действий", "status-pill-process");

      // Move to bottom button position
      await moveCursor("88%", "68%");
      if (!isRunning) return;

      // Click
      if (cursor) cursor.classList.add('clicking');
      await new Promise(r => {
        const t = setTimeout(r, 200);
        timeouts.push(t);
      });
      if (cursor) cursor.classList.remove('clicking');

      const ctaSection = document.getElementById('mock-cta');
      if (ctaSection) {
        ctaSection.classList.add('visible');
      }

      // Hide cursor
      if (cursor) {
        cursor.style.opacity = "0";
        cursor.style.left = "85%";
        cursor.style.top = "80%";
      }

      await new Promise(r => {
        const t = setTimeout(r, 600);
        timeouts.push(t);
      });
      if (!isRunning) return;

      // --- STEP 5: CONVERSION EXPLOSION ---
      if (viewport) viewport.classList.add('optimized-mode');
      
      animatePercentage(8.5, 12.8, 1000);

      await new Promise(r => {
        const t = setTimeout(r, 1000);
        timeouts.push(t);
      });
      if (!isRunning) return;

      // Dock the badge in the header bar
      if (badge) {
        badge.classList.remove('centered');
        badge.classList.add('docked');
      }
      updateStatusPill("Сайт оптимизирован", "status-pill-success");

      await new Promise(r => {
        const t = setTimeout(r, 800);
        timeouts.push(t);
      });
      if (!isRunning) return;

      // --- STEP 6: CRM LEAD NOTIFICATIONS STACKING ---
      const leads = [
        { title: "Заявка на расчет: Коттедж 180 м²", contact: "+7 (921) ***-**-44" },
        { title: "Запись на бесплатный замер воздуха", contact: "@dmitry_vent" },
        { title: "Заявка на монтаж: Квартира 74 м²", contact: "@elena_spb" }
      ];

      for (let idx = 0; idx < leads.length; idx++) {
        if (!isRunning) return;
        addLeadNotification(leads[idx].title, leads[idx].contact);
        await new Promise(r => {
          const t = setTimeout(r, 1200);
          timeouts.push(t);
        });
      }

      // Restart Loop after showing leads
      const tRestart = setTimeout(() => {
        if (!isRunning) return;
        runTimeline();
      }, 5000);
      timeouts.push(tRestart);
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting && !hasRunOnce) {
          hasRunOnce = true;
          runTimeline();
        }
      });
    }, {
      threshold: 0.3
    });

    observer.observe(container);
  };


  document.addEventListener('DOMContentLoaded', () => {
    handleForm();
    handleSiteTransformation();
  });
</script>
